@model IEnumerable<MedicalInsuranceApp1.Models.Entities.AccountingEntry>
@{
    ViewData["Title"] = "القيود المحاسبية";
    int    selMonth  = (int)ViewBag.Month;
    int    selYear   = (int)ViewBag.Year;
    string selStatus = ViewBag.Status as string ?? "";

    decimal totalDebitSum  = (decimal)(ViewBag.TotalDebit     ?? 0m);
    decimal totalBankSum   = (decimal)(ViewBag.TotalBankDebit ?? 0m);
    int     cntPending     = (int)(ViewBag.CountPending  ?? 0);
    int     cntComplete    = (int)(ViewBag.CountComplete  ?? 0);
    int     cntApproved    = (int)(ViewBag.CountApproved  ?? 0);

    var monthNames = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames;
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
    <div>
        <h2 style="font-size:19px;font-weight:800;color:#fff">
            <i class="ti ti-balance" style="margin-left:8px;color:#9b59b6"></i>القيود المحاسبية
        </h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">
            قيود مزدوجة مُولَّدة تلقائياً من أوامر التوريد وإيصالات القبض
        </p>
    </div>
</div>

@* ── بطاقات الملخص ── *@
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:24px">
    <div class="stat-card" style="border-right:4px solid #e67e22">
        <div class="stat-label">إجمالي مدين</div>
        <div class="stat-value" style="color:#e67e22">@totalDebitSum.ToString("N3") د.ل</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #2980b9">
        <div class="stat-label">إيداع مصرفي</div>
        <div class="stat-value" style="color:#2980b9">@totalBankSum.ToString("N3") د.ل</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #e67e22">
        <div class="stat-label">مبدئي</div>
        <div class="stat-value" style="color:#e67e22">@cntPending</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #2980b9">
        <div class="stat-label">مكتمل</div>
        <div class="stat-value" style="color:#2980b9">@cntComplete</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #27ae60">
        <div class="stat-label">معتمد</div>
        <div class="stat-value" style="color:#27ae60">@cntApproved</div>
    </div>
</div>

@* ── فلاتر ── *@
<div class="table-card" style="padding:14px 20px;margin-bottom:18px">
    <form method="get" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end">
        <div>
            <label class="filter-label">الشهر</label>
            <select name="month" class="filter-select" onchange="this.form.submit()">
                @for (int m = 1; m <= 12; m++)
                {
                    string mn = new DateTime(2000, m, 1).ToString("MMMM");
                    if (m == selMonth)
                    {
                        <option value="@m" selected>@mn</option>
                    }
                    else
                    {
                        <option value="@m">@mn</option>
                    }
                }
            </select>
        </div>
        <div>
            <label class="filter-label">السنة</label>
            <select name="year" class="filter-select" onchange="this.form.submit()">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                {
                    if (y == selYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <div>
            <label class="filter-label">الحالة</label>
            <select name="status" class="filter-select" onchange="this.form.submit()">
                <option value="">— الكل —</option>
                @foreach (var st in new[] { "مبدئي", "مكتمل", "معتمد" })
                {
                    if (st == selStatus)
                    {
                        <option value="@st" selected>@st</option>
                    }
                    else
                    {
                        <option value="@st">@st</option>
                    }
                }
            </select>
        </div>
    </form>
</div>

@* ── جدول القيود ── *@
<div class="table-card" style="padding:0;overflow:hidden">
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px;color:#9a9890">
            <i class="ti ti-balance" style="font-size:40px;display:block;margin-bottom:12px;opacity:.3"></i>
            لا توجد قيود في هذه الفترة
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>رقم القيد</th>
                    <th>التاريخ</th>
                    <th>البيان</th>
                    <th style="text-align:center">مدين (د.ل)</th>
                    <th style="text-align:center">دائن (د.ل)</th>
                    <th style="text-align:center">الحالة</th>
                    <th style="text-align:center">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    decimal linesDebit  = e.Lines.Sum(l => l.Debit);
                    decimal linesCredit = e.Lines.Sum(l => l.Credit);
                    decimal showDebit   = linesDebit  > 0 ? linesDebit  : e.DebitAmount;
                    string  statusColor = e.Status switch {
                        "مبدئي" => "#e67e22",
                        "مكتمل" => "#2980b9",
                        "معتمد" => "#27ae60",
                        _        => "#888"
                    };
                    <tr>
                        <td>
                            <span style="font-family:monospace;font-weight:700;color:#6c3483;font-size:13px">
                                @(e.EntryNumber ?? $"JV-{e.Id:D5}")
                            </span>
                        </td>
                        <td style="white-space:nowrap;color:#666;font-size:12px">
                            @e.EntryDate.ToString("yyyy/MM/dd")
                        </td>
                        <td style="max-width:260px;font-size:12px">
                            @e.Description
                            @if (e.SupplyOrder != null)
                            {
                                <div style="color:#888;font-size:11px;margin-top:2px">
                                    أمر توريد: @e.SupplyOrder.OrderNumber
                                </div>
                            }
                            @if (e.BankDepositSlip != null)
                            {
                                <div style="color:#2980b9;font-size:11px;margin-top:1px">
                                    إيداع: @e.BankDepositSlip.SlipNumber
                                </div>
                            }
                        </td>
                        <td style="text-align:center;font-weight:700;color:#c0392b;font-size:13px">
                            @showDebit.ToString("N3")
                        </td>
                        <td style="text-align:center;font-weight:700;color:#27ae60;font-size:13px">
                            @(linesCredit > 0 ? linesCredit.ToString("N3") : "—")
                        </td>
                        <td style="text-align:center">
                            <span style="background:@(statusColor + "22");color:@statusColor;
                                         border:1px solid @statusColor;
                                         padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700">
                                @e.Status
                            </span>
                        </td>
                        <td style="text-align:center;white-space:nowrap">
                            <a href="/AccountingEntries/Details/@e.Id"
                               style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;
                                      background:#6c3483;color:#fff;border-radius:6px;font-size:12px;text-decoration:none">
                                <i class="ti ti-eye"></i> عرض
                            </a>
                            <a href="/AccountingEntries/Print/@e.Id" target="_blank"
                               style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;
                                      background:#2c3e50;color:#fff;border-radius:6px;font-size:12px;
                                      text-decoration:none;margin-right:4px">
                                <i class="ti ti-printer"></i>
                            </a>
                            <button onclick="openDelete(@e.Id, '@Html.Raw(e.EntryNumber ?? $"JV-{e.Id:D5}")')"
                                    style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;
                                           background:#c0392b;color:#fff;border-radius:6px;font-size:12px;
                                           border:none;cursor:pointer;margin-right:4px">
                                <i class="ti ti-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- modal الحذف -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:12px;padding:28px;width:420px;max-width:95%;box-shadow:0 8px 32px rgba(0,0,0,.2)">
        <div style="font-size:16px;font-weight:700;color:#c0392b;margin-bottom:6px">
            <i class="ti ti-trash"></i> حذف القيد
        </div>
        <div id="deleteEntryNum" style="font-size:13px;color:#666;margin-bottom:16px"></div>
        <label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px">
            سبب الحذف <span style="color:#c0392b">*</span>
        </label>
        <textarea id="deleteReason" rows="3"
                  style="width:100%;padding:10px;border:1px solid #e0e0d8;border-radius:8px;
                         font-family:Cairo,sans-serif;font-size:13px;resize:vertical;box-sizing:border-box"
                  placeholder="اكتب سبب الحذف..."></textarea>
        <div style="display:flex;gap:10px;margin-top:18px;justify-content:flex-end">
            <button onclick="closeDelete()"
                    style="padding:8px 20px;border:1px solid #ccc;border-radius:8px;
                           background:#f5f5f0;cursor:pointer;font-family:Cairo,sans-serif">إلغاء</button>
            <form id="deleteForm" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reason" id="deleteReasonInput" />
                <button type="submit"
                        style="padding:8px 20px;background:#c0392b;color:#fff;border:none;
                               border-radius:8px;cursor:pointer;font-family:Cairo,sans-serif;font-weight:700">
                    <i class="ti ti-trash"></i> تأكيد الحذف
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openDelete(id, num) {
    document.getElementById('deleteEntryNum').textContent = 'رقم القيد: ' + num;
    document.getElementById('deleteReason').value = '';
    document.getElementById('deleteForm').action  = '/AccountingEntries/Delete/' + id;
    var m = document.getElementById('deleteModal');
    m.style.display = 'flex';
}
function closeDelete() {
    document.getElementById('deleteModal').style.display = 'none';
}
document.getElementById('deleteForm').addEventListener('submit', function(e) {
    var r = document.getElementById('deleteReason').value.trim();
    if (!r) { e.preventDefault(); alert('يرجى كتابة سبب الحذف'); return; }
    document.getElementById('deleteReasonInput').value = r;
});
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .stat-card  { background:var(--card-bg,#fff);border-radius:10px;padding:14px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08); }
    .stat-label { font-size:11px;color:#888;margin-bottom:4px; }
    .stat-value { font-size:18px;font-weight:800; }
    .filter-label  { font-size:11px;color:#888;display:block;margin-bottom:4px; }
    .filter-select { padding:7px 10px;border:1px solid #e0e0d8;border-radius:7px;font-family:Cairo,sans-serif;font-size:13px;background:#fafaf8; }
    .data-table    { width:100%;border-collapse:collapse; }
    .data-table th { background:#f5f0fc;color:#6c3483;font-size:12px;padding:10px 12px;border-bottom:2px solid #e0d8f0;text-align:right; }
    .data-table td { padding:10px 12px;border-bottom:1px solid #f0f0ec;font-size:13px;vertical-align:middle; }
    .data-table tbody tr:hover { background:#faf8ff; }
    </style>
}
