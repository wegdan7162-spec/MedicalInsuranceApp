@model MedicalInsuranceApp1.Models.Entities.SupplyOrder
@{
    ViewData["Title"] = "إضافة أمر توريد";
    var suppliers = (IEnumerable<MedicalInsuranceApp1.Models.Entities.Supplier>)ViewBag.Suppliers;
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/SupplyOrders" class="btn-back"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إضافة أمر توريد</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">تسجيل أمر توريد قسط تأمين طبي</p>
    </div>
</div>

<div class="table-card" style="max-width:720px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <!-- رقم أمر التوريد يُولَّد تلقائياً من السيرفر — حقل مخفي فارغ -->
        <input type="hidden" asp-for="OrderNumber" value="" />

        <div class="form-grid">

            <!-- رقم أمر التوريد — عرض فقط -->
            <div class="form-group">
                <label class="form-label">رقم أمر التوريد</label>
                <div class="auto-number-box" id="orderNumberDisplay">
                    <i class="ti ti-reload spin" id="numLoader" style="display:none;font-size:14px"></i>
                    <span id="orderNumberText">يُولَّد تلقائياً بعد اختيار الجهة</span>
                </div>
            </div>

            <!-- تاريخ الأمر -->
            <div class="form-group">
                <label class="form-label">تاريخ الأمر <span style="color:#c0392b">*</span></label>
                <input asp-for="OrderDate" type="date" class="form-input" required />
            </div>

            <!-- الجهة الموردة — من جدول الموردين -->
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">الجهة الموردة <span style="color:#c0392b">*</span></label>
                <select name="SupplierId" id="supplierSelect" class="form-input" required
                        onchange="onSupplierChange(this)">
                    <option value="">— اختر الجهة الموردة —</option>
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.Id"
                                data-name="@s.Name"
                                data-contract="@(s.ContractNumber ?? string.Empty)"
                                data-type="@(s.EntityType ?? string.Empty)">
                            @s.Name
                            @if (!string.IsNullOrEmpty(s.ContractNumber))
                            { <text> — @s.ContractNumber</text> }
                        </option>
                    }
                </select>
            </div>

            <!-- رقم العقد — يتعبأ تلقائياً للعرض -->
            <div class="form-group">
                <label class="form-label">رقم العقد</label>
                <input type="text" id="contractNumberDisplay" class="form-input readonly-field"
                       readonly placeholder="يتعبأ تلقائياً" />
            </div>

            <!-- اسم المنشأة (مخفي من المستخدم، يُرسَل للسيرفر) -->
            <div class="form-group">
                <label class="form-label">نوع الجهة</label>
                <input type="text" id="entityTypeDisplay" class="form-input readonly-field"
                       readonly placeholder="خاصة / عامة" />
            </div>

            <!-- حقل مخفي لاسم المنشأة يُرسَل مع النموذج -->
            <input type="hidden" asp-for="FacilityName" id="facilityNameHidden" />

            <!-- فترة الغطاء -->
            <div class="form-group">
                <label class="form-label">من تاريخ <span style="color:#c0392b">*</span></label>
                <input asp-for="CoverageFrom" type="date" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">إلى تاريخ <span style="color:#c0392b">*</span></label>
                <input asp-for="CoverageTo" type="date" class="form-input" required />
            </div>

            <!-- وصف الفترة -->
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">وصف الفترة / الربع</label>
                <input asp-for="QuarterDescription" class="form-input"
                       placeholder="مثال: الربع الثاني 2025" />
            </div>

            <!-- المبلغ -->
            <div class="form-group" style="background:#f0faf4;padding:14px;border-radius:10px;
                        border:1px solid #b8e0c8;grid-column:1/-1">
                <label class="form-label" style="color:#2d6a4f">
                    مبلغ أمر التوريد (د.ل) <span style="color:#c0392b">*</span>
                </label>
                <input asp-for="Amount" type="number" step="0.001" min="0" class="form-input"
                       id="amountInput" style="font-size:18px;font-weight:700;color:#2d6a4f" required />
            </div>

            <!-- الحالة والملاحظات -->
            <div class="form-group">
                <label class="form-label">الحالة</label>
                <select asp-for="Status" class="form-input">
                    <option value="قيد التحصيل">قيد التحصيل</option>
                    <option value="مُوَرَّد">مُوَرَّد</option>
                    <option value="ملغي">ملغي</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">ملاحظات</label>
                <input asp-for="Notes" class="form-input" placeholder="أي ملاحظات..." />
            </div>
        </div>

        <div style="display:flex;gap:10px;margin-top:24px">
            <button type="submit" class="btn-primary" id="submitBtn" disabled>
                <i class="ti ti-device-floppy"></i> حفظ أمر التوريد
            </button>
            <a href="/SupplyOrders" class="btn-cancel">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
async function onSupplierChange(sel) {
    var opt = sel.options[sel.selectedIndex];
    if (!opt.value) {
        resetForm();
        return;
    }

    // تعبئة الحقول من بيانات المورد
    document.getElementById("facilityNameHidden").value   = opt.dataset.name     || "";
    document.getElementById("contractNumberDisplay").value = opt.dataset.contract || "";
    document.getElementById("entityTypeDisplay").value    = opt.dataset.type     || "";

    // جلب رقم أمر التوريد التالي
    var numText   = document.getElementById("orderNumberText");
    var numLoader = document.getElementById("numLoader");
    numText.textContent = "جاري التوليد...";
    numLoader.style.display = "inline";

    try {
        var resp = await fetch("/SupplyOrders/NextOrderNumber");
        var num  = await resp.json();
        numText.textContent = num;
    } catch {
        numText.textContent = "سيُولَّد عند الحفظ";
    } finally {
        numLoader.style.display = "none";
    }

    document.getElementById("submitBtn").disabled = false;
}

function resetForm() {
    document.getElementById("facilityNameHidden").value    = "";
    document.getElementById("contractNumberDisplay").value = "";
    document.getElementById("entityTypeDisplay").value     = "";
    document.getElementById("orderNumberText").textContent = "يُولَّد تلقائياً بعد اختيار الجهة";
    document.getElementById("submitBtn").disabled = true;
}
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-label { font-size:13px; font-weight:600; }
    .form-input {
        padding:10px 12px; border:1px solid #e0e0d8; border-radius:8px;
        font-family:Cairo,sans-serif; font-size:13px; background:var(--input-bg,#fafaf8);
    }
    .form-input:focus { outline:none; border-color:#1B4332; box-shadow:0 0 0 3px rgba(27,67,50,0.1); }
    .readonly-field { background:#f0f0ec !important; color:#555; cursor:not-allowed; }
    .auto-number-box {
        padding:10px 14px;
        border:2px dashed #1B4332;
        border-radius:8px;
        background:#f0faf4;
        color:#1B4332;
        font-weight:700;
        font-size:15px;
        letter-spacing:2px;
        min-height:42px;
        display:flex;
        align-items:center;
        gap:8px;
    }
    .spin { animation: spin 1s linear infinite; display:inline-block; }
    @@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
    </style>
}
