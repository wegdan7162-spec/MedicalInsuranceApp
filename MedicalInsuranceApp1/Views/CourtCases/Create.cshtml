@* @model MedicalInsuranceApp1.Models.ViewModels.CourtCaseCreateVM
@{
    ViewData["Title"] = "مطالبة جديدة";
}

<div style="max-width:700px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a href="/CourtCases" class="btn-back">
            <i class="ti ti-arrow-right"></i>
        </a>
        <div>
            <h2 style="font-size:18px;font-weight:700;color:#ffffff">تسجيل مطالبة قضية جديدة</h2>
            <p style="font-size:13px;color:#9a9890">أدخل بيانات المطالبة</p>
        </div>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="error-box"></div>

        <div class="form-card">
            <div class="form-section-title">
                <i class="ti ti-user"></i> بيانات المدعي
            </div>
            <div class="form-grid">
                <div class="form-group" style="grid-column:span 2">
                    <label asp-for="PlaintiffName">
                        اسم المدعي <span class="req">*</span>
                    </label>
                    <input asp-for="PlaintiffName" class="form-input"
                           placeholder="أدخل اسم المدعي كاملاً">
                    <span asp-validation-for="PlaintiffName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="BranchId">الفرع <span class="req">*</span></label>
                    <select asp-for="BranchId" asp-items="Model.Branches"
                            class="form-select">
                        <option value="">-- اختر الفرع --</option>
                    </select>
                    <span asp-validation-for="BranchId" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="CourtId">المحكمة <span class="req">*</span></label>
                    <select asp-for="CourtId" asp-items="Model.Courts"
                            class="form-select">
                        <option value="">-- اختر المحكمة --</option>
                    </select>
                    <span asp-validation-for="CourtId" class="field-error"></span>
                </div>
                <div class="form-group" style="grid-column:span 2">
                    <label asp-for="Place">مكان الواقعة</label>
                    <input asp-for="Place" class="form-input" placeholder="أدخل مكان الواقعة">
                </div>
                <div class="form-group">
                    <label asp-for="IncidentDate">تاريخ الواقعة</label>
                    <input asp-for="IncidentDate" type="date" class="form-input">
                </div>
            </div>
        </div>

        <div class="form-card">
            <div class="form-section-title">
                <i class="ti ti-cash"></i> البيانات المالية
            </div>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="RegDate">تاريخ التسجيل <span class="req">*</span></label>
                    <input asp-for="RegDate" type="date" class="form-input">
                    <span asp-validation-for="RegDate" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ClaimStatus">حالة المطالبة</label>
                    <select asp-for="ClaimStatus" class="form-select">
                        @foreach (var s in Model.StatusList)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ClaimType">نوع المطالبة</label>
                    <select asp-for="ClaimType" class="form-select">
                        @foreach (var t in Model.ClaimTypeList)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="FileStatus">حالة الملف</label>
                    <select asp-for="FileStatus" class="form-select">
                        @foreach (var s in Model.FileStatusList)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Reserve">قيمة الاحتياطي</label>
                    <input asp-for="Reserve" type="number" step="0.01"
                           class="form-input" placeholder="0.00">
                </div>
                <div class="form-group">
                    <label asp-for="Setteld">المبلغ المسدد</label>
                    <input asp-for="Setteld" type="number" step="0.01"
                           class="form-input" placeholder="0.00">
                </div>
            </div>
        </div>

        <div class="form-card">
            <div class="form-section-title">
                <i class="ti ti-notes"></i> ملاحظات ومرفقات
            </div>
            <div class="form-group" style="margin-bottom:16px">
                <label asp-for="Note">الملاحظات</label>
                <textarea asp-for="Note" class="form-textarea" rows="3"
                          placeholder="أدخل أي ملاحظات..."></textarea>
            </div>
            <div class="form-group">
                <label>رفع مرفق (PDF أو صورة)</label>
                <input type="file" name="file" class="form-file"
                       accept=".pdf,.jpg,.jpeg,.png">
            </div>
        </div>

        <div style="display:flex;gap:12px;justify-content:flex-end">
            <a href="/CourtCases" class="btn-cancel">إلغاء</a>
            <button type="submit" class="btn-save">
                <i class="ti ti-device-floppy"></i> حفظ المطالبة
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
} *@