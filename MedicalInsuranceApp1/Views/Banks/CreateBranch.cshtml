@model MedicalInsuranceApp1.Models.Entities.BankBranch
@{
    ViewData["Title"] = "إضافة فرع";
}

<style>
    .bank-form-wrapper {
        max-width: 580px;
        margin: 0 auto;
    }

    .bank-form-card {
        background: var(--card-bg, #fff);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.10);
    }

    .bank-card-header {
        background: linear-gradient(135deg, #1a3a5c 0%, #1B4332 60%, #2d6a4f 100%);
        padding: 28px 28px 24px;
        position: relative;
        overflow: hidden;
    }

    .bank-card-header::before {
        content: '';
        position: absolute;
        top: -40px;
        left: -40px;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
    }

    .bank-icon-circle {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: rgba(255,255,255,0.18);
        border: 1.5px solid rgba(255,255,255,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

    .bank-card-body {
        padding: 28px 28px 24px;
    }

    .parent-bank-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 14px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 30px;
        color: #fff;
        font-size: 12.5px;
        font-weight: 700;
        margin-bottom: 16px;
        backdrop-filter: blur(4px);
    }

    .form-field {
        margin-bottom: 18px;
    }

    .form-field label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-primary, #2a3520);
        margin-bottom: 8px;
    }

    .form-field label .field-icon {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        background: #eaf2f8;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3a5c;
        font-size: 13px;
    }

    .required-star { color: #e53e3e; font-size: 15px; line-height: 1; }

    .pro-input {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid var(--border-color, #e0ddd5);
        border-radius: 10px;
        font-family: Cairo, sans-serif;
        font-size: 13.5px;
        color: var(--text-primary, #2a3520);
        background: var(--input-bg, #fafaf7);
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
        outline: none;
    }

    .pro-input:focus {
        border-color: #1a3a5c;
        box-shadow: 0 0 0 3px rgba(26,58,92,0.10);
        background: #fff;
    }

    .pro-input::placeholder { color: #bbb8b0; }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 18px;
    }

    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 16px;
        background: var(--hover-bg, #f7f5f0);
        border-radius: 12px;
        border: 1.5px solid var(--border-color, #e8e5dc);
        margin-bottom: 24px;
    }

    .toggle-label {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toggle-icon {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        background: #eaf2f8;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3a5c;
        font-size: 15px;
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
    }

    .switch input { display: none; }

    .slider {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background: #d0cdc5;
        border-radius: 24px;
        transition: .3s;
    }

    .slider:before {
        content: '';
        position: absolute;
        height: 18px;
        width: 18px;
        right: 3px;
        bottom: 3px;
        background: white;
        border-radius: 50%;
        transition: .3s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    }

    input:checked + .slider { background: #1a3a5c; }
    input:checked + .slider:before { transform: translateX(-20px); }

    .divider {
        height: 1px;
        background: var(--border-color, #e8e5dc);
        margin: 6px 0 20px;
    }

    .form-actions { display: flex; gap: 12px; }

    .btn-save-branch {
        flex: 1;
        padding: 12px;
        background: linear-gradient(135deg, #1a3a5c, #2563a8);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-family: Cairo, sans-serif;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(26,58,92,0.35);
    }

    .btn-save-branch:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(26,58,92,0.45);
    }

    .btn-finish {
        padding: 12px 18px;
        border: 1.5px solid var(--border-color, #ddd);
        border-radius: 12px;
        color: var(--text-secondary, #6a6a50);
        text-decoration: none;
        font-family: Cairo, sans-serif;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
        background: var(--input-bg, #fafaf7);
        white-space: nowrap;
    }

    .btn-finish:hover {
        border-color: #2d6a4f;
        color: #2d6a4f;
        background: #e8f5ee;
    }

    .success-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #e8f5ee;
        border: 1px solid #b5d9c5;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 13px;
        font-weight: 600;
        color: #1B4332;
    }
</style>

<!-- رأس الصفحة -->
<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/Banks" class="btn-back" title="رجوع"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">المصارف وفروعها</h2>
        <p style="font-size:12px;color:#9a9890;margin-top:2px">إضافة فرع — @ViewBag.BankName</p>
    </div>
</div>

<div class="bank-form-wrapper">
    <div class="bank-form-card">

        <!-- Header -->
        <div class="bank-card-header">
            <div class="parent-bank-badge">
                <i class="ti ti-building-bank"></i>
                @ViewBag.BankName
            </div>
            <div class="bank-icon-circle">
                <i class="ti ti-git-branch" style="font-size:22px;color:#fff"></i>
            </div>
            <div style="color:#fff;font-size:18px;font-weight:800;position:relative;z-index:1">إضافة فرع جديد</div>
            <div style="color:rgba(255,255,255,0.65);font-size:12px;margin-top:4px;position:relative;z-index:1">
                يمكنك إضافة أكثر من فرع للمصرف
            </div>

            <!-- Steps indicator -->
            <div style="display:flex;align-items:center;gap:8px;margin-top:18px;position:relative;z-index:1">
                <div style="display:flex;align-items:center;gap:6px;opacity:0.6">
                    <div style="width:24px;height:24px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.6);color:#fff;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center">
                        <i class="ti ti-check" style="font-size:12px"></i>
                    </div>
                    <span style="color:#fff;font-size:12px;font-weight:600">بيانات المصرف</span>
                </div>
                <div style="flex:1;height:1.5px;background:rgba(255,255,255,0.35);border-radius:2px;max-width:50px"></div>
                <div style="display:flex;align-items:center;gap:6px">
                    <div style="width:24px;height:24px;border-radius:50%;background:#fff;color:#1a3a5c;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center">٢</div>
                    <span style="color:#fff;font-size:12px;font-weight:600">إضافة الفروع</span>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="bank-card-body">

            @if (TempData["Success"] != null)
            {
                <div class="success-alert">
                    <i class="ti ti-circle-check" style="font-size:18px;color:#2d6a4f"></i>
                    @TempData["Success"]
                </div>
            }

            <form method="post" action="/Banks/CreateBranch">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BankId" value="@ViewBag.BankId">

                <!-- كود + اسم الفرع -->
                <div style="display:grid;grid-template-columns:140px 1fr;gap:14px">
                    <div class="form-field">
                        <label>
                            <span class="field-icon"><i class="ti ti-hash"></i></span>
                            الكود
                        </label>
                        <input type="text" name="BranchCode" value="@Model?.BranchCode"
                               class="pro-input" placeholder="BR-01" style="font-family:monospace">
                    </div>
                    <div class="form-field">
                        <label>
                            <span class="field-icon"><i class="ti ti-git-branch"></i></span>
                            اسم الفرع
                            <span class="required-star">*</span>
                        </label>
                        <input type="text" name="BranchName" value="@Model?.BranchName"
                               class="pro-input" placeholder="مثال: فرع طرابلس المركزي" required autofocus>
                    </div>
                </div>

                <!-- العنوان والهاتف -->
                <div class="fields-grid">
                    <div>
                        <label style="display:flex;align-items:center;gap:7px;font-size:13px;font-weight:700;color:var(--text-primary,#2a3520);margin-bottom:8px">
                            <span class="field-icon"><i class="ti ti-map-pin"></i></span>
                            العنوان
                        </label>
                        <input type="text" name="Address" value="@Model?.Address"
                               class="pro-input" placeholder="اختياري">
                    </div>
                    <div>
                        <label style="display:flex;align-items:center;gap:7px;font-size:13px;font-weight:700;color:var(--text-primary,#2a3520);margin-bottom:8px">
                            <span class="field-icon"><i class="ti ti-phone"></i></span>
                            الهاتف
                        </label>
                        <input type="text" name="Phone" value="@Model?.Phone"
                               class="pro-input" placeholder="اختياري" style="font-family:monospace">
                    </div>
                </div>

                <div class="divider"></div>

                <!-- حالة الفرع Toggle -->
                <div class="toggle-row">
                    <div class="toggle-label">
                        <div class="toggle-icon"><i class="ti ti-toggle-right"></i></div>
                        <div>
                            <div style="font-size:13px;font-weight:700;color:var(--text-primary,#2a3520)">حالة الفرع</div>
                            <div style="font-size:11.5px;color:#9a9890;margin-top:1px">تفعيل أو تعطيل الفرع</div>
                        </div>
                    </div>
                    <label class="switch">
                        <input type="checkbox" name="IsActive" value="true" id="isActive"
                               @(Model == null || Model.IsActive ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                    <input type="hidden" name="IsActive" value="false">
                </div>

                <!-- الأزرار -->
                <div class="form-actions">
                    <a href="/Banks" class="btn-finish">
                        <i class="ti ti-check"></i> انتهيت
                    </a>
                    <button type="submit" class="btn-save-branch">
                        <i class="ti ti-plus"></i> إضافة الفرع
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
