@model MedicalInsuranceApp1.Models.Entities.InsuranceContract
@{
    ViewData["Title"] = "إضافة عقد تأمين";
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/InsuranceContracts" class="btn-back"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إضافة عقد تأمين طبي</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">تسجيل عقد تأمين طبي جديد مع قسم الاكتتاب</p>
    </div>
</div>

<div class="table-card" style="max-width:820px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div style="font-size:13px;font-weight:700;color:#1a3a5c;border-bottom:1px solid #e8e8e0;padding-bottom:10px;margin-bottom:20px">
            <i class="ti ti-building-hospital" style="margin-left:6px"></i> بيانات المنشأة والعقد
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">رقم العقد</label>
                <input asp-for="ContractNumber" class="form-input" placeholder="مثال: MED-2025-001" />
            </div>
            <div class="form-group">
                <label class="form-label">الحالة</label>
                <select asp-for="Status" class="form-input">
                    <option value="نشط">نشط</option>
                    <option value="منتهي">منتهي</option>
                    <option value="ملغي">ملغي</option>
                </select>
            </div>
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">اسم المنشأة الصحية <span style="color:#c0392b">*</span></label>
                <input asp-for="FacilityName" class="form-input"
                       placeholder="مثال: مصحة الأطلس التخصصية" required />
            </div>
            <div class="form-group">
                <label class="form-label">نوع المنشأة</label>
                <select asp-for="FacilityType" class="form-input">
                    <option value="0">خاص</option>
                    <option value="1">حكومي</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label"></label>
            </div>
            <div class="form-group">
                <label class="form-label">تاريخ بداية التأمين <span style="color:#c0392b">*</span></label>
                <input asp-for="InsuranceStartDate" type="date" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">تاريخ نهاية التأمين <span style="color:#c0392b">*</span></label>
                <input asp-for="InsuranceEndDate" type="date" class="form-input" required />
            </div>
        </div>

        <div style="font-size:13px;font-weight:700;color:#1a3a5c;border-bottom:1px solid #e8e8e0;padding-bottom:10px;margin:24px 0 20px">
            <i class="ti ti-calculator" style="margin-left:6px"></i> الأقساط والمبالغ
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">القسط الخاص (د.ل)</label>
                <input asp-for="PrivatePremium" type="number" step="0.001" min="0" class="form-input" placeholder="0.000"
                       id="privPremium" oninput="calcTotal()" />
            </div>
            <div class="form-group">
                <label class="form-label">القسط الحكومي (د.ل)</label>
                <input asp-for="PublicPremium" type="number" step="0.001" min="0" class="form-input" placeholder="0.000"
                       id="pubPremium" oninput="calcTotal()" />
            </div>
            <div class="form-group">
                <label class="form-label">رسوم الإشراف (د.ل)</label>
                <input asp-for="SupervisionFee" type="number" step="0.001" min="0" class="form-input" placeholder="0.000" />
            </div>
            <div class="form-group">
                <label class="form-label">مبلغ مقدم (د.ل)</label>
                <input asp-for="PrepaidAmount" type="number" step="0.001" min="0" class="form-input" placeholder="0.000" />
            </div>
            <div class="form-group" style="background:#fff8e8;padding:14px;border-radius:10px;border:1px solid #f0d080">
                <label class="form-label" style="color:#92711a">تحت التحصيل (د.ل)</label>
                <input asp-for="UnderCollectionAmount" type="number" step="0.001" min="0" class="form-input"
                       id="underColl" placeholder="0.000" style="font-weight:700;color:#c9a84c" />
            </div>
            <div class="form-group" style="background:#f0faf4;padding:14px;border-radius:10px;border:1px solid #b8e0c8">
                <label class="form-label" style="color:#2d6a4f">الخزينة المحصلة (د.ل)</label>
                <input asp-for="TreasuryAmount" type="number" step="0.001" min="0" class="form-input"
                       placeholder="0.000" style="font-weight:700;color:#2d6a4f" />
            </div>
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">ملاحظات</label>
                <textarea asp-for="Notes" class="form-input" rows="2" placeholder="أي ملاحظات..."></textarea>
            </div>
        </div>

        <div style="display:flex;gap:10px;margin-top:24px">
            <button type="submit" class="btn-primary"><i class="ti ti-device-floppy"></i> حفظ العقد</button>
            <a href="/InsuranceContracts" class="btn-cancel">إلغاء</a>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
    .form-group{display:flex;flex-direction:column;gap:6px;}
    .form-label{font-size:13px;font-weight:600;}
    .form-input{padding:10px 12px;border:1px solid #e0e0d8;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;background:var(--input-bg,#fafaf8);}
    .form-input:focus{outline:none;border-color:#1B4332;box-shadow:0 0 0 3px rgba(27,67,50,0.1);}
    </style>
}
