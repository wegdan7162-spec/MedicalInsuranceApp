@model List<MedicalInsuranceApp1.Models.Entities.InsuranceContract>
@{
    ViewData["Title"] = "عقود التأمين الطبي";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div style="display:flex;align-items:center;gap:12px">
        <a href="/Dashboard/Index" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <div>
            <h2 style="font-size:18px;font-weight:700;color:#ffffff">عقود التأمين الطبي</h2>
            <p style="font-size:13px;color:#9a9890;margin-top:2px">إجمالي @Model.Count عقد</p>
        </div>
    </div>
    <a href="/InsuranceContracts/Create" class="btn-primary">
        <i class="ti ti-plus"></i> عقد جديد
    </a>
</div>

<!-- بطاقات الإجماليات -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px">
    <div class="stat-card" style="border-right:4px solid #1a3a5c">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">قسط خاص</div>
        <div style="font-size:18px;font-weight:700;color:#1a3a5c">@(((decimal)ViewBag.TotalPrivate).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #2d6a4f">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">قسط حكومي</div>
        <div style="font-size:18px;font-weight:700;color:#2d6a4f">@(((decimal)ViewBag.TotalPublic).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #c9a84c">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">قيد التحصيل</div>
        <div style="font-size:18px;font-weight:700;color:#c9a84c">@(((decimal)ViewBag.TotalUnderCollection).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #6c3483">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">الخزينة المحصلة</div>
        <div style="font-size:18px;font-weight:700;color:#6c3483">@(((decimal)ViewBag.TotalTreasury).ToString("N3"))</div>
    </div>
</div>

<!-- فلاتر -->
<div class="filter-card" style="margin-bottom:20px">
    <form method="get">
        <div class="filter-grid">
            <div class="filter-group">
                <input type="text" name="search" value="@ViewBag.Search" class="filter-input"
                       placeholder="بحث باسم المنشأة أو رقم العقد...">
            </div>
            <div class="filter-group">
                @{ string? _sa = ViewBag.Status == "نشط"  ? "selected" : null;
                   string? _se = ViewBag.Status == "منتهي" ? "selected" : null;
                   string? _sc = ViewBag.Status == "ملغي"  ? "selected" : null; }
                <select name="status" class="filter-select">
                    <option value="">كل الحالات</option>
                    <option value="نشط"  selected="@_sa">نشط</option>
                    <option value="منتهي" selected="@_se">منتهي</option>
                    <option value="ملغي"  selected="@_sc">ملغي</option>
                </select>
            </div>
            <div class="filter-group">
                @{ string? _fp = ViewBag.FacilityType == "Private" ? "selected" : null;
                   string? _fg = ViewBag.FacilityType == "Public"  ? "selected" : null; }
                <select name="facilityType" class="filter-select">
                    <option value="">كل الأنواع</option>
                    <option value="Private" selected="@_fp">خاص</option>
                    <option value="Public"  selected="@_fg">حكومي</option>
                </select>
            </div>
            <div class="filter-group">
                <select name="year" class="filter-select">
                    <option value="">كل السنوات</option>
                    @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 4; y--)
                    {
                        string? _ySel = ViewBag.Year?.ToString() == y.ToString() ? "selected" : null;
                        <option value="@y" selected="@_ySel">@y</option>
                    }
                </select>
            </div>
            <div class="filter-group" style="display:flex;gap:8px">
                <button type="submit" class="btn-primary" style="flex:1"><i class="ti ti-search"></i> بحث</button>
                <a href="/InsuranceContracts" class="btn-cancel" style="flex:1;display:flex;align-items:center;justify-content:center;gap:4px">
                    <i class="ti ti-x"></i> إعادة
                </a>
            </div>
        </div>
    </form>
</div>

@Html.AntiForgeryToken()

<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>رقم العقد</th>
                <th>اسم المنشأة</th>
                <th>النوع</th>
                <th>بداية التأمين</th>
                <th>نهاية التأمين</th>
                <th>القسط الخاص</th>
                <th>القسط الحكومي</th>
                <th>الخزينة</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="11" style="text-align:center;padding:40px;color:#9a9890">
                        <i class="ti ti-file-text" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        لا توجد عقود — أضف عقداً جديداً
                    </td>
                </tr>
            }
            else
            {
                int i = 1;
                @foreach (var item in Model)
                {
                <tr>
                    <td style="color:#9a9890">@(i++)</td>
                    <td style="font-family:monospace;font-size:12px">@(item.ContractNumber ?? "—")</td>
                    <td><strong>@item.FacilityName</strong></td>
                    <td>
                        @if (item.FacilityType == MedicalInsuranceApp1.Models.Entities.FacilityType.Private)
                        { <span style="background:#e8f0fe;color:#1a3a5c;padding:2px 8px;border-radius:12px;font-size:12px">خاص</span> }
                        else
                        { <span style="background:#e8f5ee;color:#2d6a4f;padding:2px 8px;border-radius:12px;font-size:12px">حكومي</span> }
                    </td>
                    <td style="font-size:12px;color:#6a6a50">@item.InsuranceStartDate.ToString("yyyy/MM/dd")</td>
                    <td style="font-size:12px;color:#6a6a50">@item.InsuranceEndDate.ToString("yyyy/MM/dd")</td>
                    <td style="font-weight:600;color:#1a3a5c">@item.PrivatePremium.ToString("N3")</td>
                    <td style="font-weight:600;color:#2d6a4f">@item.PublicPremium.ToString("N3")</td>
                    <td style="font-weight:700;color:#6c3483">@item.TreasuryAmount.ToString("N3")</td>
                    <td>
                        @if (item.Status == "نشط")
                        { <span style="background:#e8f5ee;color:#2d6a4f;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">نشط</span> }
                        else if (item.Status == "منتهي")
                        { <span style="background:#f0f0e8;color:#6a6a50;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">منتهي</span> }
                        else
                        { <span style="background:#fde8e8;color:#c0392b;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">ملغي</span> }
                    </td>
                    <td>
                        <div style="display:flex;gap:4px;flex-wrap:wrap">
                            <a href="/InsuranceContracts/Details/@item.Id" class="btn-icon"
                               style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px;background:#e8f0fe;color:#1a3a5c">
                                <i class="ti ti-eye"></i>
                            </a>
                            <a href="/SupplyOrders/Create?contractId=@item.Id" class="btn-icon"
                               style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px;background:#e8f5ee;color:#2d6a4f">
                                <i class="ti ti-plus"></i> <span style="font-size:11px">أمر</span>
                            </a>
                            <a href="/InsuranceContracts/Edit/@item.Id" class="btn-icon"
                               style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px">
                                <i class="ti ti-edit"></i>
                            </a>
                            <button type="button" class="btn-icon danger"
                                    onclick="showDelete(@item.Id,'@item.FacilityName')"
                                    style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px">
                                <i class="ti ti-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Delete Modal -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg,#fff);border-radius:16px;padding:28px;width:420px;max-width:90vw">
        <h3 style="font-size:16px;font-weight:700;color:#c0392b;margin-bottom:8px">تأكيد الحذف</h3>
        <p style="font-size:13px;color:#6a6a50;margin-bottom:16px">هل أنت متأكد من حذف عقد <strong id="deleteName"></strong>؟</p>
        <form id="deleteForm" method="post" action="/InsuranceContracts/Delete">
            <input type="hidden" name="id" id="deleteId"/>
            @Html.AntiForgeryToken()
            <div style="margin-bottom:16px">
                <input type="text" name="reason" placeholder="سبب الحذف..."
                       style="width:100%;padding:10px 12px;border:1px solid #e0e0d8;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;box-sizing:border-box"/>
            </div>
            <div style="display:flex;gap:10px">
                <button type="submit" style="flex:1;padding:10px;background:#c0392b;color:#fff;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">حذف</button>
                <button type="button" onclick="document.getElementById('deleteModal').style.display='none'" style="flex:1;padding:10px;background:#f5f5f0;color:#3a4a28;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">إلغاء</button>
            </div>
        </form>
    </div>
</div>
<script>
function showDelete(id, name) {
    document.getElementById("deleteName").textContent = name;
    document.getElementById("deleteId").value = id;
    document.getElementById("deleteModal").style.display = "flex";
}
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .stat-card{background:var(--card-bg,#fff);border-radius:12px;padding:16px 20px;border:1px solid #e8e8e0;}
    </style>
}
