@model MedicalInsuranceApp1.Models.Entities.CaseFeeSettlement
@{
    ViewData["Title"] = "تعديل تسوية أتعاب قضية";
}

<div style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a href="/CaseFeeSettlements" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">تعديل تسوية أتعاب قضية</h2>
    </div>

    <form action="/CaseFeeSettlements/Edit/@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id">
        <div class="form-card">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="form-group">
                    <label>رقم القضية <span class="req">*</span></label>
                    <input type="text" name="CaseNumber" class="form-input" value="@Model.CaseNumber" required>
                </div>
                <div class="form-group">
                    <label>السنة <span class="req">*</span></label>
                    <input type="number" name="Year" class="form-input" value="@Model.Year" required>
                </div>
                <div class="form-group">
                    <label>المحكمة</label>
                    <select name="CourtId" class="form-input">
                        <option value="">-- اختر المحكمة --</option>
                        @foreach (var c in ViewBag.Courts) {
                            <option value="@c.Id" selected="@(Model.CourtId == c.Id ? "selected" : null)">@c.CourtName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>الفرع</label>
                    <select name="BranchId" class="form-input">
                        <option value="">-- اختر الفرع --</option>
                        @foreach (var b in ViewBag.Branches) {
                            <option value="@b.Id" selected="@(Model.BranchId == b.Id ? "selected" : null)">@b.BranchName</option>
                        }
                    </select>
                </div>
                <div class="form-group" style="grid-column:1/-1">
                    <label>اسم المحامي <span class="req">*</span></label>
                    <input type="text" name="LawyerName" class="form-input" value="@Model.LawyerName" required>
                </div>
                <div class="form-group">
                    <label>الأتعاب المتفق عليها</label>
                    <input type="number" step="0.01" name="AgreeAmount" class="form-input" value="@Model.AgreeAmount">
                </div>
                <div class="form-group">
                    <label>المبلغ المدفوع</label>
                    <input type="number" step="0.01" name="PaidAmount" class="form-input" value="@Model.PaidAmount">
                </div>
                <div class="form-group">
                    <label>تاريخ العقد</label>
                    <input type="date" name="ContractDate" class="form-input"
                           value="@(Model.ContractDate.HasValue ? Model.ContractDate.Value.ToString("yyyy-MM-dd") : "")">
                </div>
                <div class="form-group">
                    <label>الحالة</label>
                    <select name="Status" class="form-input">
                        <option value="قيد الدفع" selected="@(Model.Status == "قيد الدفع" ? "selected" : null)">قيد الدفع</option>
                        <option value="مدفوع" selected="@(Model.Status == "مدفوع" ? "selected" : null)">مدفوع</option>
                        <option value="ملغى" selected="@(Model.Status == "ملغى" ? "selected" : null)">ملغى</option>
                    </select>
                </div>
            </div>
            <div class="form-group" style="margin-top:8px">
                <label>ملاحظات</label>
                <textarea name="Notes" class="form-input" rows="3">@Model.Notes</textarea>
            </div>
        </div>
        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:16px">
            <a href="/CaseFeeSettlements" class="btn-cancel">إلغاء</a>
            <button type="submit" class="btn-save"><i class="ti ti-device-floppy"></i> حفظ التعديلات</button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
