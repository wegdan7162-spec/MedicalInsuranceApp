@model MedicalInsuranceApp1.ViewModels.Identity.ForgotPasswordVM

<style>
    .fade-slide {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity .6s ease, transform .6s ease;
    }

        .fade-slide.show {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="container mt-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0 rounded-4 fade-slide" id="forgotCard">

                <div class="card-header text-center bg-light border-0 rounded-top-4 py-4">
                    <h3 class="fw-bold text-secondary">Forgot Password</h3>
                </div>

                <div class="card-body px-4 py-4">

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="example@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 mt-2">
                            Send to Email
                        </button>

                    </form>

                    <div class="text-center mt-4">
                        <a asp-action="Login" asp-controller="Account" class="text-decoration-none text-primary">
                            Back to Login
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.addEventListener('load', () => {
            document.getElementById('forgotCard').classList.add('show');
        });
    </script>
}
