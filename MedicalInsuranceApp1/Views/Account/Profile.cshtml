@model MedicalInsuranceApp1.Models.ViewModels.UserProfileVM

@{
    ViewData["Title"] = "الملف الشخصي";
}

<style>
    /* ===== PAGE ===== */
    .profile-page {
        min-height: 100vh;
        background: #f8f6f0;
        padding: 16px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* subtle orbs */
    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.12;
        pointer-events: none;
        animation: floatOrb 9s ease-in-out infinite;
    }
    .orb-1 { width: 350px; height: 350px; background: #2d6a4f; top: -80px; left: -80px; animation-delay: 0s; }
    .orb-2 { width: 250px; height: 250px; background: #c9a84c; bottom: -60px; right: -60px; animation-delay: 4s; }
    .orb-3 { width: 180px; height: 180px; background: #2980b9; top: 50%; left: 65%; animation-delay: 2s; }

    @@keyframes floatOrb {
        0%, 100% { transform: translateY(0) scale(1); }
        50%       { transform: translateY(-25px) scale(1.06); }
    }

    /* ===== CARD ===== */
    .profile-card {
        background: #fff;
        border: 1px solid #eeede8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 6px 24px rgba(27,67,50,0.1);
        opacity: 0;
        transform: translateY(25px);
        transition: opacity 0.55s ease, transform 0.55s ease;
        max-width: 400px;
        width: 100%;
        margin: 0 auto;
    }
    .profile-card.show { opacity: 1; transform: translateY(0); }

    /* ===== HEADER ===== */
    .profile-header {
        background: linear-gradient(135deg, #1B4332, #2d6a4f);
        padding: 16px 20px 12px;
        text-align: center;
        border-bottom: 1px solid #eeede8;
    }

    .avatar-ring {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2d6a4f, #c9a84c);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
        box-shadow: 0 0 14px rgba(201,168,76,0.4);
        animation: pulseRing 3s ease-in-out infinite;
    }
    @@keyframes pulseRing {
        0%, 100% { box-shadow: 0 0 14px rgba(201,168,76,0.4); }
        50%       { box-shadow: 0 0 24px rgba(201,168,76,0.65); }
    }
    .avatar-ring i { font-size: 1.6rem; color: #fff; }

    .profile-header h5 {
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 2px;
    }
    .profile-header .job-title {
        color: rgba(255,255,255,0.72);
        font-size: 0.73rem;
    }

    /* ===== INFO GRID ===== */
    .info-grid { padding: 12px 12px 8px; }

    .info-item {
        background: #f8f6f0;
        border: 1px solid #eeede8;
        border-radius: 10px;
        padding: 8px 10px;
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.4s ease, transform 0.4s ease, background 0.2s;
    }
    .info-item:hover {
        background: #e8f5ee;
        transform: translateY(-1px);
    }
    .info-item.show { opacity: 1; transform: translateY(0); }

    .info-item .icon-dot {
        width: 22px; height: 22px;
        border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.72rem;
        margin-bottom: 5px;
    }
    .info-item .lbl {
        font-size: 0.6rem;
        font-weight: 700;
        color: #9a9890;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 2px;
    }
    .info-item .val {
        font-size: 0.78rem;
        font-weight: 600;
        color: #1B4332;
    }

    /* icon palettes — dashboard colours */
    .ic-green  { background: #e8f5ee; color: #1a7a4a; }
    .ic-gold   { background: #fdf6e3; color: #c9a84c; }
    .ic-blue   { background: #eaf1fb; color: #1a5276; }
    .ic-olive  { background: #e8f5ee; color: #2d6a4f; }
    .ic-amber  { background: #fdf6e3; color: #c9a84c; }

    /* ===== STATUS ===== */
    .status-active {
        display: inline-flex; align-items: center; gap: 4px;
        background: #e8f5ee;
        border: 1px solid #1a7a4a;
        color: #1a7a4a;
        border-radius: 20px; padding: 1px 8px;
        font-size: 0.72rem; font-weight: 600;
    }
    .status-inactive {
        display: inline-flex; align-items: center; gap: 4px;
        background: #fceaea;
        border: 1px solid #c0392b;
        color: #c0392b;
        border-radius: 20px; padding: 1px 8px;
        font-size: 0.72rem; font-weight: 600;
    }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .dot-green { background: #1a7a4a; box-shadow: 0 0 5px #1a7a4a; animation: blink 2s infinite; }
    .dot-red   { background: #c0392b; }
    @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

    /* ===== ROLE BADGE ===== */
    .role-badge {
        display: inline-block;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 0.68rem; font-weight: 600;
        margin: 1px;
        background: #fdf6e3;
        border: 1px solid #c9a84c;
        color: #8a6a00;
    }

    /* ===== DIVIDER ===== */
    .glass-divider {
        border: none;
        border-top: 1px solid #eeede8;
        margin: 0 12px;
    }

    /* ===== BUTTON ===== */
    .btn-dash {
        display: block; text-align: center; text-decoration: none;
        background: #1B4332;
        border: none;
        color: #fff;
        font-weight: 600; font-size: 0.82rem;
        border-radius: 10px; padding: 8px 0;
        box-shadow: 0 3px 10px rgba(27,67,50,0.3);
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .btn-dash:hover {
        background: #2d6a4f;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(27,67,50,0.4);
        color: #fff;
    }
</style>

<div class="profile-page">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div style="width:100%; max-width:400px;">

        <div class="profile-card" id="profileCard">

            <!-- Header -->
            <div class="profile-header">
                <div class="avatar-ring">
                    <i class="bi bi-person-fill"></i>
                </div>
                <h5>@Model.FullName</h5>
                <span class="job-title">
                    <i class="bi bi-briefcase-fill me-1" style="color:#e8c96d;"></i>
                    @(string.IsNullOrEmpty(Model.UserJob) ? "لا توجد وظيفة محددة" : Model.UserJob)
                </span>
            </div>

            <!-- Info -->
            <div class="info-grid">
                <div class="row g-2">

                    <div class="col-6">
                        <div class="info-item" id="item1">
                            <div class="icon-dot ic-green"><i class="bi bi-person-badge"></i></div>
                            <div class="lbl">اسم المستخدم</div>
                            <div class="val">@Model.UserName</div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="info-item" id="item2">
                            <div class="icon-dot ic-olive"><i class="bi bi-shield-check"></i></div>
                            <div class="lbl">الحالة</div>
                            <div class="val">
                                @if (Model.IsActive)
                                {
                                    <span class="status-active"><span class="status-dot dot-green"></span> نشط</span>
                                }
                                else
                                {
                                    <span class="status-inactive"><span class="status-dot dot-red"></span> غير نشط</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="info-item" id="item3">
                            <div class="icon-dot ic-blue"><i class="bi bi-calendar-plus"></i></div>
                            <div class="lbl">تاريخ الإنشاء</div>
                            <div class="val">@Model.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd")</div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="info-item" id="item4">
                            <div class="icon-dot ic-gold"><i class="bi bi-clock-history"></i></div>
                            <div class="lbl">آخر دخول</div>
                            <div class="val">
                                @(Model.LastLoginAt.HasValue
                                    ? Model.LastLoginAt.Value.ToLocalTime().ToString("yyyy/MM/dd hh:mm tt")
                                    : "—")
                            </div>
                        </div>
                    </div>

                    @if (Model.Roles.Any())
                    {
                        <div class="col-12">
                            <div class="info-item" id="item5">
                                <div class="icon-dot ic-amber"><i class="bi bi-stars"></i></div>
                                <div class="lbl">الصلاحيات</div>
                                <div class="val">
                                    @foreach (var role in Model.Roles)
                                    {
                                        <span class="role-badge">@role</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>

            <hr class="glass-divider" />

            <div class="px-3 pb-3 pt-2">
                <a asp-action="ChangePassword" class="btn-dash">
                    <i class="bi bi-key-fill me-2"></i>تغيير كلمة المرور
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.addEventListener('load', () => {
            setTimeout(() => document.getElementById('profileCard').classList.add('show'), 100);
            ['item1','item2','item3','item4','item5'].forEach((id, i) => {
                const el = document.getElementById(id);
                if (el) setTimeout(() => el.classList.add('show'), 380 + i * 110);
            });
        });
    </script>
}
