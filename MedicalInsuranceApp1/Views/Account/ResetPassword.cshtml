@model MedicalInsuranceApp1.ViewModels.Identity.ResetPasswordVM

<style>
    .fade-slide {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity .6s ease, transform .6s ease;
    }

        .fade-slide.show {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="container mt-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0 rounded-4 fade-slide" id="resetCard">

                <div class="card-header text-center bg-light border-0 rounded-top-4 py-4">
                    <h3 class="fw-bold text-secondary">Reset Password</h3>
                </div>

                <div class="card-body px-4 py-4">

                    <form asp-action="ResetPassword" asp-controller="Account" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Token" type="hidden" />

                        <div class="mb-3 position-relative">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control form-control-lg" id="pass1" />
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 me-3 translate-middle-y text-secondary" style="cursor:pointer" onclick="togglePass('pass1', this)"></i>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3 position-relative">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" id="pass2" />
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 me-3 translate-middle-y text-secondary" style="cursor:pointer" onclick="togglePass('pass2', this)"></i>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 mt-2">
                            Reset Password
                        </button>

                    </form>

                    <div class="text-center mt-4">
                        <a asp-action="Login" asp-controller="Account" class="text-decoration-none text-primary">
                            Back to Login
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Show animation
        window.addEventListener('load', () => {
            document.getElementById('resetCard').classList.add('show');
        });

        function togglePass(id, icon) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
}
