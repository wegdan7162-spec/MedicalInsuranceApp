@model MedicalInsuranceApp1.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "تغيير كلمة المرور";
}
<div style="max-width:500px;margin:40px auto;font-family:Cairo,sans-serif;direction:rtl">
    <h2 style="color:#1B4332;margin-bottom:24px">تغيير كلمة المرور</h2>

    <div asp-validation-summary="ModelOnly"
         style="background:#fceaea;padding:12px;border-radius:8px;
                color:#c0392b;margin-bottom:16px;font-size:13px"></div>

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        <div style="margin-bottom:16px">
            <label style="font-size:13px;color:#555;display:block;margin-bottom:6px">
                كلمة المرور الحالية
            </label>
            <input asp-for="CurrentPassword" type="password"
                   style="width:100%;height:42px;padding:0 14px;border:1.5px solid #ddd;
                          border-radius:8px;font-family:Cairo,sans-serif;font-size:14px;outline:none">
            <span asp-validation-for="CurrentPassword" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div style="margin-bottom:16px">
            <label style="font-size:13px;color:#555;display:block;margin-bottom:6px">
                كلمة المرور الجديدة
            </label>
            <input asp-for="NewPassword" type="password"
                   style="width:100%;height:42px;padding:0 14px;border:1.5px solid #ddd;
                          border-radius:8px;font-family:Cairo,sans-serif;font-size:14px;outline:none">
            <span asp-validation-for="NewPassword" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div style="margin-bottom:24px">
            <label style="font-size:13px;color:#555;display:block;margin-bottom:6px">
                تأكيد كلمة المرور
            </label>
            <input asp-for="ConfirmPassword" type="password"
                   style="width:100%;height:42px;padding:0 14px;border:1.5px solid #ddd;
                          border-radius:8px;font-family:Cairo,sans-serif;font-size:14px;outline:none">
            <span asp-validation-for="ConfirmPassword" style="color:#c0392b;font-size:12px"></span>
        </div>

        <button type="submit"
                style="width:100%;height:44px;background:#1B4332;color:white;border:none;
                       border-radius:8px;font-family:Cairo,sans-serif;font-size:15px;
                       font-weight:700;cursor:pointer">
            حفظ كلمة المرور
        </button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}