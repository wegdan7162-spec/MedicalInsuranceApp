@using MedicalInsuranceApp1.Models.ViewModels.Identity
@model UserProfile

@{
    ViewData["Title"] = "User Profile";
}

<style>
    .fade-slide {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

        .fade-slide.show {
            opacity: 1;
            transform: translateY(0);
        }

    .profile-img {
        width: 250px;
        height: 250px;
        border-radius: 50%;
        object-fit: cover;
        cursor: pointer;
        transition: 0.3s;
    }

        .profile-img:hover {
            opacity: 0.85;
            transform: scale(1.03);
        }
</style>

<div class="container my-5">
    <div class="row d-flex justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 fade-slide" id="profileCard">

                <div class="card-header text-center bg-white border-0 pt-4 pb-0">
                    <h4 class="fw-bold text-secondary">User Profile</h4>
                </div>

                <div class="card-body text-dark">

                    <form asp-action="UserProfile" enctype="multipart/form-data">

                        <div class="row">

                            <!-- LEFT SIDE -->
                            <div class="col-md-6 fade-slide" id="leftColumn">

                                <div class="mb-4">
                                    <label asp-for="DisplayName" class="form-label fw-semibold"></label>
                                    <input asp-for="DisplayName" class="form-control form-control-lg" placeholder="Enter your name" />
                                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                                </div>

                                <div class="bg-light border rounded-3 p-3 mb-4 text-center">
                                    <label class="fw-semibold d-block mb-2">Gender</label>
                                    <div class="d-flex justify-content-center gap-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="gender" value="true" @(Model?.Gender == true ? "checked" : "") />
                                            <label class="form-check-label">Male</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="gender" value="false" @(Model?.Gender == false ? "checked" : "") />
                                            <label class="form-check-label">Female</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="p-3 bg-light border rounded-3 mb-4">
                                    <p class="mb-1">
                                        <b>@Html.DisplayNameFor(m => m.Created):</b>
                                        @Html.DisplayFor(m => m.CreatedDateLocalTime)
                                        @* @Html.HiddenFor(m => m.Created) *@ @*زائدة*@
                                    </p>
                                    <p class="mb-0">
                                        <b>@Html.DisplayNameFor(m => m.Modified):</b>
                                        @Html.DisplayFor(m => m.ModifiedDateLocalTime)
                                    </p>
                                </div>

                                <div class="mt-4">
                                    <h6 class="fw-bold">Email:</h6>
                                    <p class="text-muted">@ViewBag.Email</p>
                                </div>

                            </div>

                            <!-- RIGHT SIDE -->
                            <div class="col-md-6 text-center fade-slide" id="rightColumn">

                                <label class="form-label fw-semibold mb-2">Profile Image</label>

                                <input id="input1" type="file" asp-for="Image"
                                       onchange="UploadImageFile(this,'img1','isImg1');"
                                       class="form-control mb-3" />

                                <input type="hidden" name="isImg1" id="isImg1" value="..." />

                                <button type="button"
                                        class="btn-close position-absolute end-0 me-4 mt-2"
                                        aria-label="Close"
                                        onclick="return clearFile('input1','img1','isImg1');">
                                </button>

                                <div class="mt-3">
                                    <img id="img1"
                                         src="@(Model?.ImageUrl != null ? Url.Content($"~/upload/{Model.ImageUrl}") : Url.Content("~/img/user.png"))"
                                         onclick="return clickFile('input1');"
                                         class="img-thumbnail profile-img" />

                                    @if (Model?.ImageUrl != null)
                                    {
                                        <input type="hidden" asp-for="ImageUrl" />
                                    }
                                </div>

                            </div>

                        </div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="mt-5 mb-3 fade-slide" id="saveButton">
                            <input type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3" value="Save" />
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/inputfileimage.js"></script>
    <script>
        window.addEventListener('load', () => {
            const profileCard = document.getElementById('profileCard');
            const leftColumn = document.getElementById('leftColumn');
            const rightColumn = document.getElementById('rightColumn');
            const saveButton = document.getElementById('saveButton');

            profileCard.classList.add('show');

            // تأخير ظهور الأعمدة بشكل متتابع
            setTimeout(() => leftColumn.classList.add('show'), 200);
            setTimeout(() => rightColumn.classList.add('show'), 400);
            setTimeout(() => saveButton.classList.add('show'), 600);
        });
    </script>
}
