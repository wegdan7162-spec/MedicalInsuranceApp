@model List<MedicalInsuranceApp1.Models.Entities.BankAccount>
@{
    ViewData["Title"] = "الحسابات المصرفية";
}

<!-- رأس الصفحة -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div style="display:flex;align-items:center;gap:12px">
        <a href="/Dashboard/Index" class="btn-back" title="رجوع">
            <i class="ti ti-arrow-right"></i>
        </a>
        <div>
            <h2 style="font-size:18px;font-weight:700;color:#ffffff">الحسابات المصرفية</h2>
            <p style="font-size:13px;color:#9a9890;margin-top:2px">@ViewBag.ActiveCount حساب نشط</p>
        </div>
    </div>
    <a href="/BankAccounts/Create" class="btn-primary">
        <i class="ti ti-plus"></i> إضافة حساب
    </a>
</div>

<!-- بطاقة إجمالي الأرصدة -->
<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:24px">
    <div class="stat-card" style="border-right:4px solid #1a3a5c">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">إجمالي الأرصدة النشطة</div>
        <div style="font-size:24px;font-weight:700;color:#1a3a5c">@(((decimal)ViewBag.TotalBalance).ToString("N3")) د.ل</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #2d6a4f">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">عدد الحسابات</div>
        <div style="font-size:24px;font-weight:700;color:#2d6a4f">@Model.Count حساب</div>
    </div>
</div>

<!-- فلتر بحث -->
<div class="filter-card" style="margin-bottom:20px">
    <form method="get">
        <div class="filter-grid">
            <div class="filter-group">
                <select name="search" class="filter-input">
                    <option value="">-- اختر المصرف --</option>
                    @foreach (var bankName in (List<string>)ViewBag.BankNames)
                    {
                        if (ViewBag.Search == bankName)
                        {
                            <option value="@bankName" selected>@bankName</option>
                        }
                        else
                        {
                            <option value="@bankName">@bankName</option>
                        }
                    }
                </select>
            </div>
            <div class="filter-group" style="display:flex;gap:8px">
                <button type="submit" class="btn-primary" style="flex:1"><i class="ti ti-search"></i> بحث</button>
                <a href="/BankAccounts" class="btn-cancel" style="flex:1;display:flex;align-items:center;justify-content:center;gap:4px">
                    <i class="ti ti-x"></i> إعادة
                </a>
            </div>
        </div>
    </form>
</div>

@Html.AntiForgeryToken()

<!-- الجدول -->
<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>اسم المصرف</th>
                <th>رقم الحساب</th>
                <th>الفرع</th>
                <th>الرصيد الافتتاحي</th>
                <th>الرصيد الحالي</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center;padding:40px;color:#9a9890">
                        <i class="ti ti-building-bank" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        لا توجد حسابات — أضف حساباً جديداً
                    </td>
                </tr>
            }
            else
            {
                int i = 1;
                @foreach (var item in Model)
                {
                <tr>
                    <td style="color:#9a9890">@(i++)</td>
                    <td><strong><i class="ti ti-building-bank" style="color:#1a3a5c;margin-left:6px"></i>@item.BankName</strong></td>
                    <td style="font-family:monospace;font-size:13px;color:#1a3a5c;font-weight:600">@item.AccountNumber</td>
                    <td style="color:#6a6a50">@(item.BankBranch ?? "—")</td>
                    <td style="color:#6a6a50">@item.OpeningBalance.ToString("N3")</td>
                    <td style="font-weight:700;font-size:15px;color:@(item.CurrentBalance >= 0 ? "#2d6a4f" : "#c0392b")">
                        @item.CurrentBalance.ToString("N3") <small style="font-size:11px;font-weight:400">د.ل</small>
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span style="background:#e8f5ee;color:#2d6a4f;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">نشط</span>
                        }
                        else
                        {
                            <span style="background:#f5f5f0;color:#9a9890;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">غير نشط</span>
                        }
                    </td>
                    <td>
                        <div style="display:flex;gap:6px;align-items:center">
                            <!-- الحركات -->
                            <a href="/BankTransactions?accountId=@item.Id" title="عرض الحركات"
                               style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:9px;background:#e8f0fe;color:#1a3a5c;text-decoration:none;transition:all .15s;border:1px solid #c5d5ef"
                               onmouseover="this.style.background='#1a3a5c';this.style.color='#fff'"
                               onmouseout="this.style.background='#e8f0fe';this.style.color='#1a3a5c'">
                                <i class="ti ti-arrows-exchange" style="font-size:16px"></i>
                            </a>
                            <!-- كشف حركة -->
                            <a href="/BankTransactions/MonthlyStatement?bankAccountId=@item.Id" title="كشف الحركة الشهرية"
                               style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:9px;background:#e8f5ee;color:#2d6a4f;text-decoration:none;transition:all .15s;border:1px solid #b5d9c5"
                               onmouseover="this.style.background='#2d6a4f';this.style.color='#fff'"
                               onmouseout="this.style.background='#e8f5ee';this.style.color='#2d6a4f'">
                                <i class="ti ti-file-spreadsheet" style="font-size:16px"></i>
                            </a>
                            <!-- تعديل -->
                            <a href="/BankAccounts/Edit/@item.Id" title="تعديل"
                               style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:9px;background:#f5f0e8;color:#92711a;text-decoration:none;transition:all .15s;border:1px solid #e0d0a0"
                               onmouseover="this.style.background='#92711a';this.style.color='#fff'"
                               onmouseout="this.style.background='#f5f0e8';this.style.color='#92711a'">
                                <i class="ti ti-edit" style="font-size:16px"></i>
                            </a>
                            <!-- إعادة حساب -->
                            <a href="/BankAccounts/RecalcBalance/@item.Id" title="إعادة حساب الرصيد"
                               onclick="return confirm('إعادة حساب الرصيد من الحركات؟')"
                               style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:9px;background:#f0eaf8;color:#6c3483;text-decoration:none;transition:all .15s;border:1px solid #d5b8e8"
                               onmouseover="this.style.background='#6c3483';this.style.color='#fff'"
                               onmouseout="this.style.background='#f0eaf8';this.style.color='#6c3483'">
                                <i class="ti ti-refresh" style="font-size:16px"></i>
                            </a>
                            <!-- حذف -->
                            <button type="button" title="حذف"
                                    onclick="showDelete(@item.Id,'@item.BankName - @item.AccountNumber')"
                                    style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:9px;background:#fde8e8;color:#c0392b;border:1px solid #f0b8b8;cursor:pointer;transition:all .15s"
                                    onmouseover="this.style.background='#c0392b';this.style.color='#fff'"
                                    onmouseout="this.style.background='#fde8e8';this.style.color='#c0392b'">
                                <i class="ti ti-trash" style="font-size:16px"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Delete Modal -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg,#fff);border-radius:16px;padding:28px;width:420px;max-width:90vw">
        <h3 style="font-size:16px;font-weight:700;color:#1B4332;margin-bottom:8px">تأكيد الحذف</h3>
        <p style="font-size:13px;color:#6a6a50;margin-bottom:20px">هل أنت متأكد من حذف <strong id="deleteName"></strong>؟</p>
        <form id="deleteForm" method="post">
            <input type="hidden" name="id" id="deleteId"/>
            @Html.AntiForgeryToken()
            <div style="display:flex;gap:10px">
                <button type="submit" style="flex:1;padding:10px;background:#c0392b;color:#fff;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">حذف</button>
                <button type="button" onclick="closeModal()" style="flex:1;padding:10px;background:#f5f5f0;color:#3a4a28;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">إلغاء</button>
            </div>
        </form>
    </div>
</div>
<script>
function showDelete(id, name) {
    document.getElementById("deleteName").textContent = name;
    document.getElementById("deleteId").value = id;
    document.getElementById("deleteForm").action = "/BankAccounts/Delete";
    document.getElementById("deleteModal").style.display = "flex";
}
function closeModal() { document.getElementById("deleteModal").style.display = "none"; }
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .stat-card { background:var(--card-bg,#fff);border-radius:12px;padding:18px 20px;border:1px solid #e8e8e0; }
    </style>
}
