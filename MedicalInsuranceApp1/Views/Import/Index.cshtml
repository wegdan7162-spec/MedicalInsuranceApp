@{
    ViewData["Title"] = "استيراد بيانات Excel";
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/Dashboard/Index" class="btn-back"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">استيراد بيانات Excel</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">استيراد كشوف حركة المصارف وكشوف بيان العمولات</p>
    </div>
</div>

<!-- رسائل النتيجة -->
@if (TempData["Success"] != null)
{
<div style="background:#e8f5ee;border:1px solid #2d6a4f;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:flex-start;gap:12px">
    <i class="ti ti-circle-check" style="color:#2d6a4f;font-size:20px;flex-shrink:0;margin-top:1px"></i>
    <div>
        <div style="font-weight:700;color:#2d6a4f">تم الاستيراد بنجاح</div>
        <div style="font-size:13px;color:#2d6a4f;margin-top:4px">@TempData["Success"]</div>
        @if (TempData["Info"] != null)
        {
        <div style="font-size:12px;color:#6a6a50;margin-top:6px;border-top:1px solid #c8e6c9;padding-top:6px">
            @TempData["Info"]
        </div>
        }
    </div>
</div>
}
@if (TempData["Error"] != null)
{
<div style="background:#fde8e8;border:1px solid #c0392b;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:flex-start;gap:12px">
    <i class="ti ti-alert-circle" style="color:#c0392b;font-size:20px;flex-shrink:0;margin-top:1px"></i>
    <div>
        <div style="font-weight:700;color:#c0392b">خطأ في الاستيراد</div>
        <div style="font-size:13px;color:#c0392b;margin-top:4px">@TempData["Error"]</div>
    </div>
</div>
}

<!-- تنبيه مهم -->
<div style="background:#fff8e1;border:1px solid #f9a825;border-radius:10px;padding:14px 18px;margin-bottom:28px;display:flex;gap:12px">
    <i class="ti ti-info-circle" style="color:#f9a825;font-size:20px;flex-shrink:0;margin-top:1px"></i>
    <div style="font-size:13px;color:#5d4037">
        <strong>تنبيه قبل الاستيراد:</strong>
        ملفات <code>.xls</code> القديمة يجب تحويلها أولاً —
        افتح الملف في Excel ثم <strong>File → Save As → Excel Workbook (.xlsx)</strong>
        <br>البيانات المستوردة مسبقاً لن تُكرَّر تلقائياً.
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">

    <!-- ===== بطاقة استيراد كشف حركة المصارف ===== -->
    <div class="table-card">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #e8e8e0">
            <div style="width:44px;height:44px;background:#e8f0fe;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="ti ti-building-bank" style="font-size:22px;color:#1a3a5c"></i>
            </div>
            <div>
                <div style="font-size:15px;font-weight:700;color:#1a3a5c">كشف حركة المصارف</div>
                <div style="font-size:12px;color:#9a9890;margin-top:2px">ملفات حركة مصارف الصحارى، الوحدة، وغيرها</div>
            </div>
        </div>

        <!-- تعليمات -->
        <div style="font-size:12px;color:#6a6a50;margin-bottom:16px;line-height:1.8">
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                كل ورقة (Sheet) في الملف تمثل شهراً
            </div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يُنشئ الحساب المصرفي تلقائياً إن لم يكن موجوداً
            </div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يتعرف على: مصرف الصحارى (2375 و 95853)، مصرف الوحدة
            </div>
            <div style="display:flex;align-items:center;gap:6px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يصنّف الحركات تلقائياً (إيداع قسط، صرف عمولة، مصاريف...)
            </div>
        </div>

        <form method="post" action="/Import/ImportBank" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div style="border:2px dashed #c8d8f0;border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all 0.2s;margin-bottom:16px"
                 onclick="document.getElementById('bankFile').click()"
                 id="bankDropZone">
                <i class="ti ti-file-spreadsheet" style="font-size:36px;color:#1a3a5c;display:block;margin-bottom:8px"></i>
                <div style="font-size:13px;font-weight:600;color:#1a3a5c">اسحب الملف هنا أو اضغط للاختيار</div>
                <div style="font-size:11px;color:#9a9890;margin-top:4px">صيغة xlsx فقط — حجم أقصى 10MB</div>
                <div id="bankFileName" style="font-size:12px;color:#2d6a4f;margin-top:8px;font-weight:600"></div>
            </div>
            <input type="file" id="bankFile" name="file" accept=".xlsx,.xls" style="display:none"
                   onchange="showFileName(this,'bankFileName','bankDropZone')">
            <button type="submit" class="btn-primary" style="width:100%;padding:12px">
                <i class="ti ti-cloud-upload"></i> استيراد كشف المصرف
            </button>
        </form>
    </div>

    <!-- ===== بطاقة استيراد كشف بيان العمولات ===== -->
    <div class="table-card">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #e8e8e0">
            <div style="width:44px;height:44px;background:#f0eaf8;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="ti ti-receipt-2" style="font-size:22px;color:#6c3483"></i>
            </div>
            <div>
                <div style="font-size:15px;font-weight:700;color:#6c3483">كشف بيان العمولات</div>
                <div style="font-size:12px;color:#9a9890;margin-top:2px">ملف كشف بيان العمولات المباشرة</div>
            </div>
        </div>

        <!-- تعليمات -->
        <div style="font-size:12px;color:#6a6a50;margin-bottom:16px;line-height:1.8">
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يستورد جميع سجلات العمولات دفعة واحدة
            </div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يستخرج اسم المستفيد تلقائياً من حقل البيان
            </div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يحسب نسبة العمولة تلقائياً (عمولة ÷ قسط × 100)
            </div>
            <div style="display:flex;align-items:center;gap:6px">
                <i class="ti ti-check" style="color:#2d6a4f"></i>
                يحدد الحالة "مصروفة" للسجلات المستوردة
            </div>
        </div>

        <form method="post" action="/Import/ImportCommissions" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div style="border:2px dashed #d8c8f0;border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all 0.2s;margin-bottom:16px"
                 onclick="document.getElementById('commFile').click()"
                 id="commDropZone">
                <i class="ti ti-file-spreadsheet" style="font-size:36px;color:#6c3483;display:block;margin-bottom:8px"></i>
                <div style="font-size:13px;font-weight:600;color:#6c3483">اسحب الملف هنا أو اضغط للاختيار</div>
                <div style="font-size:11px;color:#9a9890;margin-top:4px">صيغة xlsx فقط — حجم أقصى 10MB</div>
                <div id="commFileName" style="font-size:12px;color:#2d6a4f;margin-top:8px;font-weight:600"></div>
            </div>
            <input type="file" id="commFile" name="file" accept=".xlsx,.xls" style="display:none"
                   onchange="showFileName(this,'commFileName','commDropZone')">
            <button type="submit" class="btn-primary" style="width:100%;padding:12px;background:#6c3483">
                <i class="ti ti-cloud-upload"></i> استيراد العمولات
            </button>
        </form>
    </div>

</div>

<!-- روابط سريعة بعد الاستيراد -->
<div style="margin-top:24px;padding:16px;background:var(--card-bg,#fff);border-radius:12px;border:1px solid #e8e8e0">
    <div style="font-size:13px;font-weight:700;color:#1a3a5c;margin-bottom:12px">
        <i class="ti ti-link" style="margin-left:6px"></i> بعد الاستيراد تحقق من:
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
        <a href="/BankAccounts" class="btn-cancel" style="font-size:12px">
            <i class="ti ti-building-bank"></i> الحسابات المصرفية
        </a>
        <a href="/BankTransactions" class="btn-cancel" style="font-size:12px">
            <i class="ti ti-arrows-exchange"></i> حركات الحسابات
        </a>
        <a href="/BankTransactions/MonthlyStatement" class="btn-cancel" style="font-size:12px">
            <i class="ti ti-file-spreadsheet"></i> كشف حركة المصارف
        </a>
        <a href="/Commissions" class="btn-cancel" style="font-size:12px">
            <i class="ti ti-receipt-2"></i> العمولات
        </a>
        <a href="/Commissions/Report" class="btn-cancel" style="font-size:12px">
            <i class="ti ti-report-money"></i> كشف بيان العمولات
        </a>
    </div>
</div>

@section Scripts {
<script>
function showFileName(input, labelId, zoneId) {
    const name = input.files[0]?.name ?? '';
    document.getElementById(labelId).textContent = name ? '✓ ' + name : '';
    const zone = document.getElementById(zoneId);
    zone.style.borderColor = name ? '#2d6a4f' : '';
    zone.style.background  = name ? '#f0faf4' : '';
}
// Drag & Drop
['bankDropZone','commDropZone'].forEach(function(id) {
    const zone = document.getElementById(id);
    if (!zone) return;
    zone.addEventListener('dragover',  e => { e.preventDefault(); zone.style.background='#f0f4ff'; });
    zone.addEventListener('dragleave', e => { zone.style.background=''; });
    zone.addEventListener('drop', function(e) {
        e.preventDefault();
        const fileInput = zone.querySelector('input[type=file]')
            ?? zone.nextElementSibling?.previousElementSibling;
        // find input inside parent form
        const form = zone.closest('form');
        const inp  = form ? form.querySelector('input[type=file]') : null;
        if (inp && e.dataTransfer.files[0]) {
            const dt = new DataTransfer();
            dt.items.add(e.dataTransfer.files[0]);
            inp.files = dt.files;
            inp.dispatchEvent(new Event('change'));
        }
    });
});
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
