@model MedicalInsuranceApp1.Models.Entities.ReceiptVoucher
@{
    ViewData["Title"] = "إضافة إيصال قبض";
    var suppliers = (IEnumerable<MedicalInsuranceApp1.Models.Entities.Supplier>)ViewBag.Suppliers;
    var ctLabels  = new Dictionary<CollectionType, string> {
        { CollectionType.Mandatory,    "إجباري" },
        { CollectionType.MedicalCard,  "بطاقة طبية" },
        { CollectionType.Supplemental, "تكميلي" },
        { CollectionType.Marine,       "بحري" },
        { CollectionType.Fires,        "حرائق" },
        { CollectionType.Miscellaneous,"متنوع" },
        { CollectionType.Various,      "مختلف" },
    };
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/ReceiptVouchers" class="btn-back"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إضافة إيصال قبض</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">تسجيل إيصال قبض قسط تأمين</p>
    </div>
</div>

<div class="table-card" style="max-width:820px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- حقول مخفية -->
        <input type="hidden" asp-for="ReceiptNumber"  id="receiptNumberHidden" value="" />
        <input type="hidden" asp-for="FacilityName"   id="facilityNameHidden"  value="" />
        <input type="hidden" asp-for="SupplyOrderId"  id="supplyOrderIdHidden" value="" />
        <input type="hidden" asp-for="DirhamAmount"   value="0" />
        <input type="hidden" asp-for="SupervisionFee" value="0" />

        <!-- ══ بيانات الإيصال ══ -->
        <div class="section-title"><i class="ti ti-receipt"></i> بيانات الإيصال</div>

        <div class="form-grid">

            <!-- رقم الإيصال — تلقائي -->
            <div class="form-group">
                <label class="form-label">رقم الإيصال</label>
                <div class="auto-number-box" id="receiptNumberDisplay">
                    <i class="ti ti-reload spin" id="numLoader" style="display:none;font-size:13px"></i>
                    <span id="receiptNumberText">يُولَّد تلقائياً بعد اختيار الجهة</span>
                </div>
            </div>

            <!-- تاريخ الإيصال -->
            <div class="form-group">
                <label class="form-label">تاريخ الإيصال <span style="color:#c0392b">*</span></label>
                <input asp-for="ReceiptDate" type="date" class="form-input" required />
            </div>

            <!-- الجهة الموردة -->
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">الجهة الموردة <span style="color:#c0392b">*</span></label>
                <select id="supplierSelect" name="_supplierId" class="form-input" required
                        onchange="onSupplierChange(this)">
                    <option value="">— اختر الجهة الموردة —</option>
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.Id"
                                data-name="@s.Name"
                                data-contract="@(s.ContractNumber ?? string.Empty)"
                                data-type="@(s.EntityType ?? string.Empty)">
                            @s.Name
                            @if (!string.IsNullOrEmpty(s.ContractNumber))
                            { <text> — @s.ContractNumber</text> }
                        </option>
                    }
                </select>
            </div>

            <!-- رقم العقد — للعرض فقط -->
            <div class="form-group">
                <label class="form-label">رقم العقد</label>
                <input type="text" id="contractNumberDisplay" class="form-input readonly-field"
                       readonly placeholder="يتعبأ تلقائياً" />
            </div>

            <!-- نوع الجهة — خاص / عام -->
            <div class="form-group">
                <label class="form-label">نوع الجهة</label>
                <div id="entityTypeBadge" class="entity-badge">
                    <span id="entityTypeText">يتعبأ بعد اختيار الجهة</span>
                </div>
            </div>

        </div>

        <!-- ══ المبلغ ══ -->
        <div class="section-title" style="margin-top:24px"><i class="ti ti-cash"></i> المبلغ</div>

        <div class="form-grid">

            <!-- المبلغ الكامل بالدينار -->
            <div class="form-group" style="grid-column:1/-1;background:#f0faf4;padding:16px;border-radius:10px;border:1px solid #b8e0c8">
                <label class="form-label" style="color:#2d6a4f;font-size:14px">
                    المبلغ بالدينار الليبي (د.ل) <span style="color:#c0392b">*</span>
                </label>
                <input asp-for="DinarAmount" type="number" step="0.001" min="0"
                       class="form-input" id="dinarAmt" oninput="syncTotal()"
                       style="font-size:22px;font-weight:800;color:#2d6a4f;text-align:center"
                       placeholder="0.000" required />
                <div style="font-size:11px;color:#888;margin-top:4px">
                    أدخل المبلغ الكامل — مثال: 30087.500
                </div>
            </div>

            <!-- الإجمالي = نفس الدينار -->
            <input type="hidden" asp-for="TotalAmount"    id="totalAmt"    value="0" />
            <input type="hidden" asp-for="TreasuryAmount" id="treasuryAmt" value="0" />

        </div>

        <!-- ══ طريقة الدفع ══ -->
        <div class="section-title" style="margin-top:24px"><i class="ti ti-credit-card"></i> طريقة الدفع</div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">طريقة الدفع</label>
                <select asp-for="PaymentMethod" class="form-input" onchange="toggleCheck(this)">
                    <option value="نقدي">نقدي</option>
                    <option value="صك">صك</option>
                    <option value="تحويل">تحويل مصرفي</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">حساب مصرفي</label>
                <select asp-for="BankAccountId" class="form-input">
                    <option value="">— اختياري —</option>
                    @foreach (var a in (IEnumerable<MedicalInsuranceApp1.Models.Entities.BankAccount>)ViewBag.BankAccounts)
                    {
                        <option value="@a.Id">@a.BankName — @a.AccountNumber</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">نوع التحصيل</label>
                <select asp-for="CollectionType" class="form-input">
                    @foreach (var ct in (IEnumerable<CollectionType>)ViewBag.CollectionTypes)
                    {
                        <option value="@((int)ct)">@(ctLabels.TryGetValue(ct, out var lbl) ? lbl : ct.ToString())</option>
                    }
                </select>
            </div>
            <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">ملاحظات</label>
                <textarea asp-for="Notes" class="form-input" rows="2" placeholder="أي ملاحظات..."></textarea>
            </div>
        </div>

        <!-- ══ بيانات الصك / التحويل ══ -->
        <div id="checkSection">
        <div class="section-title" style="margin-top:24px"><i class="ti ti-building-bank"></i> بيانات الصك / التحويل</div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">رقم الصك المودع من الجهة</label>
                <input asp-for="CheckNumber" class="form-input" placeholder="رقم الصك..." />
            </div>
            <div class="form-group">
                <label class="form-label">اسم المصرف</label>
                <input asp-for="BankName" class="form-input" placeholder="اسم المصرف..." />
            </div>
            <div class="form-group">
                <label class="form-label">اسم الفرع</label>
                <input asp-for="BankBranchName" class="form-input" placeholder="اسم فرع المصرف..." />
            </div>
        </div>
        </div><!-- /checkSection -->

        <div style="display:flex;gap:10px;margin-top:24px">
            <button type="submit" class="btn-primary" id="submitBtn" disabled>
                <i class="ti ti-device-floppy"></i> حفظ الإيصال
            </button>
            <a href="/ReceiptVouchers" class="btn-cancel">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
async function onSupplierChange(sel) {
    var opt = sel.options[sel.selectedIndex];
    if (!opt.value) { resetForm(); return; }

    // تعبئة البيانات الأساسية
    document.getElementById("facilityNameHidden").value    = opt.dataset.name     || "";
    document.getElementById("contractNumberDisplay").value = opt.dataset.contract || "";

    // نوع الجهة — خاص أو عام
    var typeTxt   = opt.dataset.type || "";
    var typeEl    = document.getElementById("entityTypeText");
    var badgeEl   = document.getElementById("entityTypeBadge");
    var isPrivate = typeTxt.includes("خاص") || typeTxt.toLowerCase().includes("private");
    typeEl.textContent   = typeTxt || (isPrivate ? "خاصة" : "عامة");
    badgeEl.className    = "entity-badge " + (isPrivate ? "private" : "public");

    // جلب رقم الإيصال التالي
    var numText = document.getElementById("receiptNumberText");
    var loader  = document.getElementById("numLoader");
    numText.textContent   = "جاري التوليد...";
    loader.style.display  = "inline";
    try {
        var r   = await fetch("/ReceiptVouchers/NextReceiptNumber");
        var num = await r.json();
        document.getElementById("receiptNumberHidden").value = num;
        numText.textContent = num;
    } catch { numText.textContent = "سيُولَّد عند الحفظ"; }
    finally   { loader.style.display = "none"; }

    // جلب أوامر التوريد المرتبطة
    try {
        var r2     = await fetch("/ReceiptVouchers/SupplyOrdersBySupplier?supplierId=" + opt.value);
        var orders = await r2.json();
        if (orders.length > 0) {
            var first = orders[0];
            document.getElementById("supplyOrderIdHidden").value = first.id;
            if (first.amount) {
                var amt = parseFloat(first.amount.replace(/,/g,"")) || 0;
                document.getElementById("dinarAmt").value = amt.toFixed(3);
                syncTotal();
            }
        }
    } catch {}

    document.getElementById("submitBtn").disabled = false;
}

function syncTotal() {
    var amt = parseFloat(document.getElementById("dinarAmt").value) || 0;
    document.getElementById("totalAmt").value    = amt.toFixed(3);
    document.getElementById("treasuryAmt").value = amt.toFixed(3);
}

function resetForm() {
    document.getElementById("facilityNameHidden").value    = "";
    document.getElementById("contractNumberDisplay").value = "";
    document.getElementById("supplyOrderIdHidden").value   = "";
    document.getElementById("receiptNumberHidden").value   = "";
    document.getElementById("receiptNumberText").textContent = "يُولَّد تلقائياً بعد اختيار الجهة";
    document.getElementById("entityTypeText").textContent  = "يتعبأ بعد اختيار الجهة";
    document.getElementById("entityTypeBadge").className   = "entity-badge";
    document.getElementById("dinarAmt").value = "";
    syncTotal();
    document.getElementById("submitBtn").disabled = true;
}

function toggleCheck(sel) {
    var val = sel.value;
    var section = document.getElementById("checkSection");
    // أخفِ القسم عند نقدي، وأظهره عند صك أو تحويل
    if (val === "نقدي") {
        section.style.display = "none";
        // امسح القيم عند الإخفاء
        section.querySelectorAll("input").forEach(function(i){ i.value = ""; });
    } else {
        section.style.display = "block";
    }
}

// تطبيق الحالة الابتدائية عند تحميل الصفحة
document.addEventListener("DOMContentLoaded", function() {
    var paymentSel = document.querySelector("select[name='PaymentMethod']");
    if (paymentSel) toggleCheck(paymentSel);
});
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-label { font-size:13px; font-weight:600; }
    .form-input { padding:10px 12px; border:1px solid #e0e0d8; border-radius:8px;
                  font-family:Cairo,sans-serif; font-size:13px; background:var(--input-bg,#fafaf8); }
    .form-input:focus { outline:none; border-color:#1B4332; box-shadow:0 0 0 3px rgba(27,67,50,0.1); }
    .readonly-field { background:#f0f0ec !important; color:#555; cursor:not-allowed; }
    .section-title { font-size:13px; font-weight:700; color:#6c3483;
                     border-bottom:1px solid #e8e8e0; padding-bottom:10px; margin-bottom:20px; }
    .section-title i { margin-left:6px; }
    .auto-number-box {
        padding:10px 14px; border:2px dashed #6c3483; border-radius:8px;
        background:#f8f0fe; color:#6c3483; font-weight:700; font-size:15px;
        letter-spacing:1px; min-height:42px; display:flex; align-items:center; gap:8px;
    }
    .entity-badge {
        padding:10px 16px; border-radius:8px; font-weight:700; font-size:14px;
        min-height:42px; display:flex; align-items:center;
        background:#f5f5f0; color:#777; border:1px solid #ddd;
    }
    .entity-badge.private { background:#e8f4f8; color:#1a6a8a; border-color:#a0cce0; }
    .entity-badge.public  { background:#f0faf4; color:#2d6a4f; border-color:#a0d4b8; }
    .entity-badge.private::before { content:"🏥 "; }
    .entity-badge.public::after   { content:" 🏛"; }
    .spin { animation:spin 1s linear infinite; display:inline-block; }
    @@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
    </style>
}
