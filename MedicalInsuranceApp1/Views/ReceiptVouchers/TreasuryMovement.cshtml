@{
    ViewData["Title"] = "إدخال حركة خزينة";
    var seqNum       = (int)ViewBag.SeqNum;
    var bankAccounts = ViewBag.BankAccounts as IEnumerable<MedicalInsuranceApp1.Models.Entities.BankAccount>;
    var suppliers    = ViewBag.Suppliers    as IEnumerable<MedicalInsuranceApp1.Models.Entities.Supplier>;
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/ReceiptVouchers/DailyReport" class="btn-back"><i class="ti ti-arrow-right"></i></a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إدخال حركة خزينة</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">تسلسل رقم @seqNum</p>
    </div>
</div>

<div class="table-card" style="max-width:860px">
    <form method="post" action="/ReceiptVouchers/TreasuryMovement">
        @Html.AntiForgeryToken()

        <!-- ══ بيانات الإيصال ══ -->
        <div class="sec-title"><i class="ti ti-receipt"></i> بيانات الإيصال</div>
        <div class="fg two">

            <div class="f">
                <label class="lbl">تسلسل</label>
                <div class="ro">@seqNum</div>
            </div>

            <div class="f">
                <label class="lbl">رقم الإيصال</label>
                <input type="text" name="receiptNumber" class="fi"
                       placeholder="RV-2026-..." />
            </div>

            <div class="f" style="grid-column:1/-1">
                <label class="lbl">الجهة الموردة <span class="req">*</span></label>
                <select name="facilityName" class="fi" required>
                    <option value="">— اختر الجهة الموردة —</option>
                    @if (suppliers != null)
                    {
                        @foreach (var s in suppliers)
                        {
                            <option value="@s.Name">@s.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="f">
                <label class="lbl">تاريخ الإيصال <span class="req">*</span></label>
                <input type="date" name="receiptDate" class="fi" required
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="f">
                <label class="lbl">طريقة الدفع</label>
                <select name="paymentMethod" class="fi">
                    <option value="صك">صك</option>
                    <option value="تحويل">تحويل مصرفي</option>
                    <option value="نقدي">نقدي</option>
                </select>
            </div>

        </div>

        <!-- ══ مدة التأمين ══ -->
        <div class="sec-title" style="margin-top:22px"><i class="ti ti-calendar"></i> مدة التأمين</div>
        <div class="fg two">
            <div class="f">
                <label class="lbl">من تاريخ</label>
                <input type="date" name="coverageFrom" class="fi" />
            </div>
            <div class="f">
                <label class="lbl">إلى تاريخ</label>
                <input type="date" name="coverageTo" class="fi" />
            </div>
        </div>

        <!-- ══ تفاصيل الأقساط ══ -->
        <div class="sec-title" style="margin-top:22px"><i class="ti ti-calculator"></i> تفاصيل الأقساط</div>
        <div class="fg two">

            <div class="f">
                <label class="lbl">القيمة الإجمالية في الإيصال (د.ل) <span class="req">*</span></label>
                <input type="number" name="totalAmount" id="totalAmount"
                       class="fi" step="0.001" min="0" required
                       placeholder="0.000" oninput="recalc()"
                       style="font-size:18px;font-weight:800;color:#1a3a5c" />
            </div>

            <div class="f">
                <label class="lbl">رسوم الإشراف <span style="color:#9a9890;font-size:11px">= الإجمالي × 0.005</span></label>
                <input type="number" name="supervisionFee" id="supervisionFee"
                       class="fi" step="0.001" min="0"
                       placeholder="0.000"
                       style="color:#6c3483;font-weight:700;background:#f5f0fc" readonly />
            </div>

            <div class="f">
                <label class="lbl">الأقساط المباشرة — خاص</label>
                <input type="number" name="privatePremium" id="privatePremium"
                       class="fi" step="0.001" min="0" placeholder="0.000"
                       style="background:#f0f8ff;font-weight:700" readonly />
            </div>

            <div class="f">
                <label class="lbl">الأقساط المباشرة — عام</label>
                <input type="number" name="publicPremium" id="publicPremium"
                       class="fi" step="0.001" min="0" placeholder="0.000" />
            </div>

            <div class="f">
                <label class="lbl">الأقساط المقدمة</label>
                <input type="number" name="advancePremium" id="advancePremium"
                       class="fi" step="0.001" min="0" placeholder="0.000"
                       oninput="recalc()" />
            </div>

            <div class="f">
                <label class="lbl">أقساط تحت الدفع</label>
                <input type="number" name="pendingPremium" id="pendingPremium"
                       class="fi" step="0.001" min="0" placeholder="0.000" />
            </div>

        </div>

        <!-- ملخص الخزينة -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px;
                    background:#f0faf4;border:1px solid #a8d5b8;border-radius:10px;padding:16px">
            <div>
                <div style="font-size:11px;color:#9a9890">صافي الخزينة (بعد رسوم الإشراف)</div>
                <div id="netDisplay" style="font-size:22px;font-weight:800;color:#1B4332">0.000 د.ل</div>
                <input type="hidden" name="netTreasury" id="netTreasury" value="0" />
            </div>
            <div>
                <div style="font-size:11px;color:#9a9890">رسوم الإشراف</div>
                <div id="feeDisplay" style="font-size:22px;font-weight:800;color:#6c3483">0.000 د.ل</div>
            </div>
        </div>

        <!-- ══ بيانات الإيداع ══ -->
        <div class="sec-title" style="margin-top:22px"><i class="ti ti-building-bank"></i> بيانات الإيداع المصرفي</div>
        <div class="fg two">

            <div class="f">
                <label class="lbl">تاريخ الإيداع <span class="req">*</span></label>
                <input type="date" name="depositDate" class="fi" required
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="f">
                <label class="lbl">رقم قسيمة الإيداع / الصك</label>
                <input type="text" name="depositSlipNumber" class="fi"
                       placeholder="رقم القسيمة أو الصك..." />
            </div>

            <div class="f" style="grid-column:1/-1">
                <label class="lbl">الحساب المصرفي <span class="req">*</span></label>
                <select name="bankAccountId" class="fi" required>
                    <option value="">— اختر الحساب —</option>
                    @if (bankAccounts != null)
                    {
                        @foreach (var a in bankAccounts)
                        {
                            <option value="@a.Id">@a.BankName — @a.AccountNumber</option>
                        }
                    }
                </select>
            </div>

            <div class="f" style="grid-column:1/-1">
                <label class="lbl">ملاحظات</label>
                <textarea name="notes" class="fi" rows="2"
                          placeholder="أي ملاحظات..."></textarea>
            </div>

        </div>

        <div style="display:flex;gap:10px;margin-top:24px">
            <button type="submit" class="btn-primary">
                <i class="ti ti-device-floppy"></i> حفظ حركة الخزينة
            </button>
            <a href="/ReceiptVouchers/DailyReport" class="btn-cancel">إلغاء</a>
        </div>

    </form>
</div>

@section Scripts {
<script>
function recalc() {
    var total  = parseFloat(document.getElementById('totalAmount').value)    || 0;
    var adv    = parseFloat(document.getElementById('advancePremium').value) || 0;

    // العمولة = (الإجمالي − المقدم إن وُجد) × 0.005
    var base   = adv > 0 ? Math.max(0, total - adv) : total;
    var fee    = Math.round(base * 0.005 * 1000) / 1000;

    // القسط المباشر = (الإجمالي − المقدم) − العمولة
    var direct = Math.round(Math.max(0, base - fee) * 1000) / 1000;

    document.getElementById('supervisionFee').value = fee.toFixed(3);
    document.getElementById('privatePremium').value = direct.toFixed(3);

    recalcNet();
}

function recalcNet() {
    var total = parseFloat(document.getElementById('totalAmount').value)    || 0;
    var fee   = parseFloat(document.getElementById('supervisionFee').value) || 0;
    // الخزينة = الإجمالي
    document.getElementById('netTreasury').value      = total.toFixed(3);
    document.getElementById('netDisplay').textContent  = total.toFixed(3) + ' د.ل';
    document.getElementById('feeDisplay').textContent  = fee.toFixed(3) + ' د.ل';
}
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .sec-title { font-size:13px;font-weight:700;color:#1B4332;
                 border-bottom:1px solid #e0e0d8;padding-bottom:10px;margin-bottom:16px; }
    .fg        { display:grid;gap:16px; }
    .two       { grid-template-columns:1fr 1fr; }
    .f         { display:flex;flex-direction:column;gap:6px; }
    .lbl       { font-size:13px;font-weight:600;color:#1B4332; }
    .req       { color:#c0392b; }
    .fi        { padding:10px 12px;border:1px solid #e0e0d8;border-radius:8px;
                 font-family:Cairo,sans-serif;font-size:13px;
                 background:var(--input-bg,#fafaf8);color:#1B4332; }
    .fi:focus  { outline:none;border-color:#1B4332;box-shadow:0 0 0 3px rgba(27,67,50,0.1); }
    .ro        { padding:10px 14px;border:1px solid #e0e0d8;border-radius:8px;
                 background:#f5f5f0;font-size:13px;font-weight:700;color:#1B4332;
                 min-height:42px;display:flex;align-items:center; }
    @@media (max-width:680px) { .two { grid-template-columns:1fr; } }
    </style>
}
