@model List<MedicalInsuranceApp1.Models.Entities.Commission>
@{
    ViewData["Title"] = "العمولات المباشرة";
}

<!-- رأس الصفحة -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div style="display:flex;align-items:center;gap:12px">
        <a href="/Dashboard/Index" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <div>
            <h2 style="font-size:18px;font-weight:700;color:#ffffff">العمولات المباشرة</h2>
            <p style="font-size:13px;color:#9a9890;margin-top:2px">إجمالي @Model.Count سجل</p>
        </div>
    </div>
    <a href="/Commissions/Create" class="btn-primary">
        <i class="ti ti-plus"></i> إضافة عمولة
    </a>
</div>

<!-- بطاقات الإجماليات -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px">
    <div class="stat-card" style="border-right:4px solid #1a3a5c">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">إجمالي الأقساط الواردة</div>
        <div style="font-size:18px;font-weight:700;color:#1a3a5c">@(((decimal)ViewBag.TotalPremium).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #c9a84c">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">إجمالي العمولات</div>
        <div style="font-size:18px;font-weight:700;color:#c9a84c">@(((decimal)ViewBag.TotalCommission).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #2d6a4f">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">المصروفة</div>
        <div style="font-size:18px;font-weight:700;color:#2d6a4f">@(((decimal)ViewBag.TotalPaid).ToString("N3"))</div>
    </div>
    <div class="stat-card" style="border-right:4px solid #c0392b">
        <div style="font-size:12px;color:#9a9890;margin-bottom:4px">قيد الصرف</div>
        <div style="font-size:18px;font-weight:700;color:#c0392b">@(((decimal)ViewBag.TotalPending).ToString("N3"))</div>
    </div>
</div>

<!-- فلاتر -->
<div class="filter-card" style="margin-bottom:20px">
    <form method="get">
        <div class="filter-grid">
            <div class="filter-group">
                <input type="text" name="search" value="@ViewBag.Search" class="filter-input"
                       placeholder="بحث بالجهة الموردة أو اسم المسوق...">
            </div>
            <div class="filter-group">
                @{ string? _s1 = ViewBag.Status == "قيد الصرف" ? "selected" : null;
                   string? _s2 = ViewBag.Status == "مصروفة"    ? "selected" : null; }
                <select name="status" class="filter-select">
                    <option value="">كل الحالات</option>
                    <option value="قيد الصرف" selected="@_s1">قيد الصرف</option>
                    <option value="مصروفة"    selected="@_s2">مصروفة</option>
                </select>
            </div>
            <div class="filter-group">
                <select name="year" class="filter-select">
                    <option value="">كل السنوات</option>
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
                    {
                        string? _ySel = ViewBag.Year?.ToString() == y.ToString() ? "selected" : null;
                        <option value="@y" selected="@_ySel">@y</option>
                    }
                </select>
            </div>
            <div class="filter-group" style="display:flex;gap:8px">
                <button type="submit" class="btn-primary" style="flex:1"><i class="ti ti-search"></i> بحث</button>
                <a href="/Commissions" class="btn-cancel" style="flex:1;display:flex;align-items:center;justify-content:center;gap:4px">
                    <i class="ti ti-x"></i> إعادة
                </a>
            </div>
        </div>
    </form>
</div>

@Html.AntiForgeryToken()

<!-- الجدول -->
<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>الجهة الموردة</th>
                <th>قيمة القسط</th>
                <th>نسبة العمولة</th>
                <th>قيمة العمولة</th>
                <th>المسوق المستفيد</th>
                <th>رقم إذن الصرف</th>
                <th>تاريخ الصرف</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="10" style="text-align:center;padding:40px;color:#9a9890">
                        <i class="ti ti-receipt-2" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        لا توجد عمولات — أضف عمولة جديدة
                    </td>
                </tr>
            }
            else
            {
                int i = 1;
                @foreach (var item in Model)
                {
                <tr>
                    <td style="color:#9a9890">@(i++)</td>
                    <td><strong>@item.SupplierName</strong></td>
                    <td style="font-weight:600;color:#1a3a5c">@item.PremiumAmount.ToString("N3")</td>
                    <td style="color:#c9a84c;font-weight:600">@item.CommissionRate %</td>
                    <td style="font-weight:700;color:#c9a84c;font-size:14px">@item.CommissionAmount.ToString("N3")</td>
                    <td style="font-size:13px">@(item.BeneficiaryName ?? "—")</td>
                    <td style="font-family:monospace;font-size:12px">@(item.AuthorizationNumber ?? "—")</td>
                    <td style="font-size:12px;color:#6a6a50">@(item.PaymentDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                    <td>
                        @if (item.Status == "مصروفة")
                        {
                            <span style="background:#e8f5ee;color:#2d6a4f;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">مصروفة</span>
                        }
                        else
                        {
                            <span style="background:#fff8e8;color:#92711a;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">قيد الصرف</span>
                        }
                    </td>
                    <td>
                        <div style="display:flex;gap:4px;flex-wrap:wrap">
                            @if (item.Status == "قيد الصرف")
                            {
                            <button type="button"
                                    onclick="showPay(@item.Id,'@item.SupplierName - @item.CommissionAmount.ToString("N3") د.ل')"
                                    class="btn-icon" style="display:inline-flex;align-items:center;gap:3px;background:#e8f5ee;color:#2d6a4f;padding:4px 8px">
                                <i class="ti ti-check"></i> <span style="font-size:11px">صرف</span>
                            </button>
                            }
                            <a href="/Commissions/Edit/@item.Id" class="btn-icon"
                               style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px">
                                <i class="ti ti-edit"></i>
                            </a>
                            <button type="button" class="btn-icon danger"
                                    onclick="showDelete(@item.Id,'@item.SupplierName')"
                                    style="display:inline-flex;align-items:center;gap:3px;padding:4px 8px">
                                <i class="ti ti-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Modal صرف العمولة -->
<div id="payModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg,#fff);border-radius:16px;padding:28px;width:460px;max-width:90vw">
        <h3 style="font-size:16px;font-weight:700;color:#2d6a4f;margin-bottom:8px">
            <i class="ti ti-check" style="margin-left:6px"></i> صرف العمولة
        </h3>
        <p style="font-size:13px;color:#6a6a50;margin-bottom:16px">
            العمولة: <strong id="payName"></strong>
        </p>
        <form id="payForm" method="post">
            <input type="hidden" name="id" id="payId"/>
            @Html.AntiForgeryToken()
            <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px">
                <div>
                    <label style="font-size:13px;font-weight:600;color:#3a4a28;display:block;margin-bottom:6px">
                        الحساب المصرفي للصرف منه
                    </label>
                    <select name="bankAccountId" class="filter-select" style="width:100%" required>
                        <option value="">— اختر الحساب —</option>
                        @foreach (var a in (ViewBag.BankAccounts ?? new List<dynamic>()))
                        {
                            <option value="@a.Id">@a.BankName — @a.AccountNumber</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="font-size:13px;font-weight:600;color:#3a4a28;display:block;margin-bottom:6px">
                        رقم الصك (اختياري)
                    </label>
                    <input type="text" name="checkNumber" placeholder="رقم الصك..."
                           style="width:100%;padding:10px 12px;border:1px solid #e0e0d8;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;box-sizing:border-box"/>
                </div>
            </div>
            <div style="display:flex;gap:10px">
                <button type="submit" style="flex:1;padding:10px;background:#2d6a4f;color:#fff;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">
                    <i class="ti ti-check"></i> تأكيد الصرف
                </button>
                <button type="button" onclick="closePayModal()" style="flex:1;padding:10px;background:#f5f5f0;color:#3a4a28;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg,#fff);border-radius:16px;padding:28px;width:420px;max-width:90vw">
        <h3 style="font-size:16px;font-weight:700;color:#1B4332;margin-bottom:8px">تأكيد الحذف</h3>
        <p style="font-size:13px;color:#6a6a50;margin-bottom:16px">هل أنت متأكد من حذف <strong id="deleteName"></strong>؟</p>
        <form id="deleteForm" method="post" action="/Commissions/Delete">
            <input type="hidden" name="id" id="deleteId"/>
            @Html.AntiForgeryToken()
            <div style="margin-bottom:16px">
                <input type="text" name="reason" placeholder="سبب الحذف..."
                       style="width:100%;padding:10px 12px;border:1px solid #e0e0d8;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;box-sizing:border-box"/>
            </div>
            <div style="display:flex;gap:10px">
                <button type="submit" style="flex:1;padding:10px;background:#c0392b;color:#fff;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">حذف</button>
                <button type="button" onclick="closeModal()" style="flex:1;padding:10px;background:#f5f5f0;color:#3a4a28;border:none;border-radius:8px;font-family:Cairo,sans-serif;font-size:13px;font-weight:600;cursor:pointer">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<script>
function showPay(id, name) {
    document.getElementById("payName").textContent = name;
    document.getElementById("payId").value = id;
    document.getElementById("payForm").action = "/Commissions/MarkPaid";
    document.getElementById("payModal").style.display = "flex";
}
function closePayModal() { document.getElementById("payModal").style.display = "none"; }
function showDelete(id, name) {
    document.getElementById("deleteName").textContent = name;
    document.getElementById("deleteId").value = id;
    document.getElementById("deleteModal").style.display = "flex";
}
function closeModal() { document.getElementById("deleteModal").style.display = "none"; }
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
    <style>
    .stat-card{background:var(--card-bg,#fff);border-radius:12px;padding:16px 20px;border:1px solid #e8e8e0;}
    </style>
}
