<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            font-size: 12px;
            color: #000;
            background: #fff;
            direction: rtl;
        }
        .print-page {
            width: 210mm;
            min-height: 297mm;
            margin: 0 auto;
            padding: 12mm 14mm;
            background: #fff;
        }
        /* ── رأس الشركة ── */
        .company-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px double #1a3a5c;
            padding-bottom: 8px;
            margin-bottom: 14px;
        }
        .company-logo {
            width: 60px;
            height: 60px;
            border: 2px solid #1a3a5c;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: #1a3a5c;
            font-weight: bold;
            text-align: center;
        }
        .company-name { font-size: 16px; font-weight: 700; color: #1a3a5c; }
        .company-sub  { font-size: 11px; color: #444; margin-top: 2px; }
        /* ── عنوان المستند ── */
        .doc-title {
            text-align: center;
            font-size: 18px;
            font-weight: 700;
            color: #1a3a5c;
            margin: 10px 0 14px;
            text-decoration: underline;
        }
        /* ── الجداول ── */
        table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
        th, td {
            border: 1px solid #333;
            padding: 4px 6px;
            text-align: center;
            font-size: 11px;
        }
        th { background: #1a3a5c; color: #fff; font-size: 11px; }
        .td-desc { text-align: right; }
        .total-row { background: #f0f4f8; font-weight: 700; }
        /* ── حقول النموذج ── */
        .field-row {
            display: flex;
            gap: 20px;
            margin-bottom: 8px;
            align-items: baseline;
        }
        .field-label { font-weight: 600; white-space: nowrap; min-width: 120px; }
        .field-value {
            border-bottom: 1px solid #333;
            flex: 1;
            min-width: 80px;
            padding-bottom: 1px;
        }
        /* ── التوقيعات ── */
        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 30px;
            gap: 20px;
        }
        .sig-box {
            flex: 1;
            text-align: center;
            border-top: 1px solid #333;
            padding-top: 4px;
            font-size: 11px;
        }
        .sig-space { height: 35px; }
        /* ── طباعة ── */
        @@media print {
            body { background: #fff !important; }
            .print-page { margin: 0; padding: 8mm 10mm; }
            .no-print { display: none !important; }
            @@page { size: A4; margin: 0; }
        }
        /* ── زر الطباعة ── */
        .btn-print {
            display: inline-block;
            background: #1a3a5c;
            color: #fff;
            border: none;
            padding: 8px 20px;
            font-size: 13px;
            cursor: pointer;
            border-radius: 4px;
            margin: 10px auto;
        }
        .print-toolbar {
            text-align: center;
            padding: 8px;
            background: #f0f4f8;
            border-bottom: 1px solid #ccc;
        }
    </style>
</head>
<body>
    <div class="no-print print-toolbar">
        <button class="btn-print" onclick="window.print()">🖨️ طباعة</button>
        <button class="btn-print" style="background:#555" onclick="window.history.back()">← رجوع</button>
    </div>
    <div class="print-page">
        @RenderBody()
    </div>
</body>
</html>
