@model MedicalInsuranceApp1.Models.ViewModels.AddExpenseVM
@{
    ViewData["Title"] = $"إضافة مصروف — مطالبة {Model.ClaimYear}-{Model.ClaimNum}";
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <a href="/OutterClaims/Details/@Model.ClaimId" class="btn-back">
        <i class="ti ti-arrow-right"></i>
    </a>
    <div>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إضافة مصروف</h2>
        <p style="font-size:13px;color:#9a9890;margin-top:2px">
            مطالبة رقم @Model.ClaimYear-@Model.ClaimNum.ToString("D4")
        </p>
    </div>
</div>

<div style="max-width:680px">

    <!-- بيانات المطالبة (للعرض فقط) -->
    <div class="form-card" style="margin-bottom:16px;background:#f8f6f0">
        <div class="form-section-title">
            <i class="ti ti-info-circle"></i> بيانات المطالبة
        </div>
        <div class="details-grid">
            <div class="detail-item">
                <span class="detail-label">رقم المطالبة</span>
                <span class="detail-value" style="font-weight:700;color:#1B4332">
                    @Model.ClaimYear-@Model.ClaimNum.ToString("D4")
                </span>
            </div>
            <div class="detail-item">
                <span class="detail-label">المدعي</span>
                <span class="detail-value">@Model.PlaintiffName</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">الفرع</span>
                <span class="detail-value">@Model.BranchName</span>
            </div>
        </div>
    </div>

    <!-- نموذج المصروف -->
    <div class="form-card">
        <div class="form-section-title">
            <i class="ti ti-receipt"></i> بيانات المصروف
        </div>

        <form asp-action="AddExpense" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ClaimId" />
            <input type="hidden" asp-for="ClaimNum" />
            <input type="hidden" asp-for="ClaimYear" />
            <input type="hidden" asp-for="PlaintiffName" />
            <input type="hidden" asp-for="BranchName" />
            <input type="hidden" asp-for="BranchId" />

            <div class="form-group">
                <label asp-for="ExpenseTypeId" class="form-label">نوع المصروف <span style="color:red">*</span></label>
                <select asp-for="ExpenseTypeId" asp-items="Model.ExpenseTypes" class="form-select">
                    <option value="">-- اختر نوع المصروف --</option>
                </select>
                <span asp-validation-for="ExpenseTypeId" class="text-danger" style="font-size:12px"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="form-group">
                    <label asp-for="Amount" class="form-label">المبلغ <span style="color:red">*</span></label>
                    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-input" placeholder="0.00" />
                    <span asp-validation-for="Amount" class="text-danger" style="font-size:12px"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ExpenseDate" class="form-label">التاريخ <span style="color:red">*</span></label>
                    <input asp-for="ExpenseDate" type="date" class="form-input" />
                    <span asp-validation-for="ExpenseDate" class="text-danger" style="font-size:12px"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">ملاحظات</label>
                <textarea asp-for="Notes" class="form-input" rows="3"
                          placeholder="أي ملاحظات إضافية..."></textarea>
            </div>

            <div style="display:flex;gap:12px;margin-top:8px">
                <button type="submit" class="btn-save">
                    <i class="ti ti-device-floppy"></i> حفظ المصروف
                </button>
                <a href="/OutterClaims/Details/@Model.ClaimId" class="btn-cancel">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
