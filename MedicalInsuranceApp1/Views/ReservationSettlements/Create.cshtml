@{
    ViewData["Title"] = "إضافة تسوية حجز";
}

<div style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a href="/ReservationSettlements" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">إضافة تسوية حجز جديدة</h2>
    </div>

    <form action="/ReservationSettlements/Create" method="post">
        @Html.AntiForgeryToken()
        <div class="form-card">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="form-group">
                    <label>رقم المطالبة <span class="req">*</span></label>
                    <input type="number" name="ClaimNum" class="form-input" placeholder="رقم المطالبة" required>
                </div>
                <div class="form-group">
                    <label>السنة <span class="req">*</span></label>
                    <input type="number" name="Year" class="form-input" value="@DateTime.Now.Year" required>
                </div>
                <div class="form-group">
                    <label>المدعي</label>
                    <select name="PlaintiffNameId" class="form-input">
                        <option value="">-- اختر المدعي --</option>
                        @foreach (var p in ViewBag.Plaintiffs) {
                            <option value="@p.Id">@p.PlainitiffName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>الفرع</label>
                    <select name="BranchId" class="form-input">
                        <option value="">-- اختر الفرع --</option>
                        @foreach (var b in ViewBag.Branches) {
                            <option value="@b.Id">@b.BranchName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>مبلغ الحجز <span class="req">*</span></label>
                    <input type="number" step="0.01" name="ReserveAmount" class="form-input" placeholder="0.00" required>
                </div>
                <div class="form-group">
                    <label>المبلغ المسوى</label>
                    <input type="number" step="0.01" name="SettledAmount" class="form-input" placeholder="0.00" value="0">
                </div>
                <div class="form-group">
                    <label>تاريخ الحجز</label>
                    <input type="date" name="ReservationDate" class="form-input">
                </div>
                <div class="form-group">
                    <label>الحالة</label>
                    <select name="Status" class="form-input">
                        <option value="قيد التسوية">قيد التسوية</option>
                        <option value="مسواة">مسواة</option>
                        <option value="ملغاة">ملغاة</option>
                    </select>
                </div>
            </div>
            <div class="form-group" style="margin-top:8px">
                <label>ملاحظات</label>
                <textarea name="Notes" class="form-input" rows="3" placeholder="ملاحظات إضافية..."></textarea>
            </div>
        </div>
        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:16px">
            <a href="/ReservationSettlements" class="btn-cancel">إلغاء</a>
            <button type="submit" class="btn-save">
                <i class="ti ti-device-floppy"></i> حفظ
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
