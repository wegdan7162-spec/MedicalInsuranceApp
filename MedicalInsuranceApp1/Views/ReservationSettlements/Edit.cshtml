@model MedicalInsuranceApp1.Models.Entities.ReservationSettlement
@{
    ViewData["Title"] = "تعديل تسوية حجز";
}

<div style="max-width:620px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a href="/ReservationSettlements" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <h2 style="font-size:18px;font-weight:700;color:#ffffff">تعديل تسوية حجز</h2>
    </div>

    <form action="/ReservationSettlements/Edit/@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id">
        <div class="form-card">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="form-group">
                    <label>رقم المطالبة <span class="req">*</span></label>
                    <input type="number" name="ClaimNum" class="form-input" value="@Model.ClaimNum" required>
                </div>
                <div class="form-group">
                    <label>السنة <span class="req">*</span></label>
                    <input type="number" name="Year" class="form-input" value="@Model.Year" required>
                </div>
                <div class="form-group">
                    <label>المدعي</label>
                    <select name="PlaintiffNameId" class="form-input">
                        <option value="">-- اختر المدعي --</option>
                        @foreach (var p in ViewBag.Plaintiffs) {
                            <option value="@p.Id" selected="@(Model.PlaintiffNameId == p.Id ? "selected" : null)">@p.PlainitiffName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>الفرع</label>
                    <select name="BranchId" class="form-input">
                        <option value="">-- اختر الفرع --</option>
                        @foreach (var b in ViewBag.Branches) {
                            <option value="@b.Id" selected="@(Model.BranchId == b.Id ? "selected" : null)">@b.BranchName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>مبلغ الحجز <span class="req">*</span></label>
                    <input type="number" step="0.01" name="ReserveAmount" class="form-input" value="@Model.ReserveAmount" required>
                </div>
                <div class="form-group">
                    <label>المبلغ المسوى</label>
                    <input type="number" step="0.01" name="SettledAmount" class="form-input" value="@Model.SettledAmount">
                </div>
                <div class="form-group">
                    <label>تاريخ الحجز</label>
                    <input type="date" name="ReservationDate" class="form-input"
                           value="@(Model.ReservationDate.HasValue ? Model.ReservationDate.Value.ToString("yyyy-MM-dd") : "")">
                </div>
                <div class="form-group">
                    <label>الحالة</label>
                    <select name="Status" class="form-input">
                        <option value="قيد التسوية" selected="@(Model.Status == "قيد التسوية" ? "selected" : null)">قيد التسوية</option>
                        <option value="مسواة" selected="@(Model.Status == "مسواة" ? "selected" : null)">مسواة</option>
                        <option value="ملغاة" selected="@(Model.Status == "ملغاة" ? "selected" : null)">ملغاة</option>
                    </select>
                </div>
            </div>
            <div class="form-group" style="margin-top:8px">
                <label>ملاحظات</label>
                <textarea name="Notes" class="form-input" rows="3">@Model.Notes</textarea>
            </div>
        </div>
        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:16px">
            <a href="/ReservationSettlements" class="btn-cancel">إلغاء</a>
            <button type="submit" class="btn-save">
                <i class="ti ti-device-floppy"></i> حفظ التعديلات
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
}
