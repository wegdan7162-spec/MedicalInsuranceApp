@model MedicalInsuranceApp1.Models.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
}

<div style="max-width:500px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a asp-action="Index" class="btn-back">
            <i class="ti ti-arrow-right"></i>
        </a>
        <div>
            <h2 style="font-size:18px;font-weight:700;color:#ffffff">إعادة تعيين كلمة المرور</h2>
            <p style="font-size:13px;color:#9a9890">المستخدم: <strong>@Model.UserName</strong></p>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id">
            <input type="hidden" asp-for="UserName">

            <div asp-validation-summary="ModelOnly" class="error-box"></div>

            <div class="form-group" style="margin-bottom:16px">
                <label asp-for="NewPassword">كلمة المرور الجديدة <span class="req">*</span></label>
                <input asp-for="NewPassword" type="password" class="form-input">
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:24px">
                <label asp-for="ConfirmPassword">تأكيد كلمة المرور <span class="req">*</span></label>
                <input asp-for="ConfirmPassword" type="password" class="form-input">
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <div style="display:flex;gap:12px;justify-content:flex-end">
                <a asp-action="Index" class="btn-cancel">إلغاء</a>
                <button type="submit" class="btn-save">
                    <i class="ti ti-lock-check"></i> تغيير كلمة المرور
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
}
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}