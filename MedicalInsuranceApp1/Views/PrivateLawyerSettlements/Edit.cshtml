@model MedicalInsuranceApp1.Models.Entities.PrivateLawyerSettlement
@{
    ViewData["Title"] = "تعديل تسوية محامي خاص";
    decimal remaining = Model.AgreeAmount - Model.PaidAmount;
}

<div style="max-width:700px">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px">
        <a href="/PrivateLawyerSettlements" class="btn-back"><i class="ti ti-arrow-right"></i></a>
        <div style="display:flex;align-items:center;gap:10px">
            <div style="width:38px;height:38px;background:linear-gradient(135deg,#92711a,#d4a017);border-radius:10px;display:flex;align-items:center;justify-content:center">
                <i class="ti ti-edit" style="color:#fff;font-size:18px"></i>
            </div>
            <div>
                <h2 style="font-size:18px;font-weight:700;color:#ffffff;margin:0">تعديل تسوية — @Model.LawyerName</h2>
                <p style="font-size:12px;color:#9a9890;margin:2px 0 0">القضية: @Model.CaseNumber | السنة: @Model.Year</p>
            </div>
        </div>
    </div>

    <form action="/PrivateLawyerSettlements/Edit/@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id">

        <!-- بيانات القضية -->
        <div class="form-card" style="margin-bottom:16px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #f0f0e8">
                <div style="width:28px;height:28px;background:#e8f0ea;border-radius:8px;display:flex;align-items:center;justify-content:center">
                    <i class="ti ti-building-courthouse" style="font-size:15px;color:#546B41"></i>
                </div>
                <span style="font-size:14px;font-weight:700;color:#3a4a28">بيانات القضية</span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
                <div class="form-group">
                    <label>رقم القضية <span class="req">*</span></label>
                    <input type="text" name="CaseNumber" class="form-input" value="@Model.CaseNumber" required>
                </div>
                <div class="form-group">
                    <label>السنة <span class="req">*</span></label>
                    <input type="number" name="Year" class="form-input" value="@Model.Year" required>
                </div>
                <div class="form-group">
                    <label>المحكمة</label>
                    <select name="CourtId" class="form-input">
                        <option value="">-- اختر المحكمة --</option>
                        @foreach (var c in ViewBag.Courts) {
                            <option value="@c.Id" selected="@(Model.CourtId == c.Id ? "selected" : null)">@c.CourtName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>الفرع</label>
                    <select name="BranchId" class="form-input">
                        <option value="">-- اختر الفرع --</option>
                        @foreach (var b in ViewBag.Branches) {
                            <option value="@b.Id" selected="@(Model.BranchId == b.Id ? "selected" : null)">@b.BranchName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>تاريخ التعاقد</label>
                    <input type="date" name="ContractDate" class="form-input"
                           value="@(Model.ContractDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
                <div class="form-group">
                    <label>تاريخ انتهاء التعاقد</label>
                    <input type="date" name="ContractEndDate" class="form-input"
                           value="@(Model.ContractEndDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
            </div>
        </div>

        <!-- بيانات المحامي -->
        <div class="form-card" style="margin-bottom:16px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #f0f0e8">
                <div style="width:28px;height:28px;background:#e8f0ea;border-radius:8px;display:flex;align-items:center;justify-content:center">
                    <i class="ti ti-user-check" style="font-size:15px;color:#546B41"></i>
                </div>
                <span style="font-size:14px;font-weight:700;color:#3a4a28">بيانات المحامي الخاص</span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                <div class="form-group" style="grid-column:1/-1">
                    <label>اسم المحامي <span class="req">*</span></label>
                    <input type="text" name="LawyerName" class="form-input" value="@Model.LawyerName" required>
                </div>
                <div class="form-group">
                    <label>رقم الجوال</label>
                    <input type="text" name="LawyerPhone" class="form-input" value="@Model.LawyerPhone" dir="ltr">
                </div>
                <div class="form-group">
                    <label>رقم الآيبان / الحساب المصرفي</label>
                    <input type="text" name="LawyerIBAN" class="form-input" value="@Model.LawyerIBAN" dir="ltr" style="letter-spacing:1px">
                </div>
            </div>
        </div>

        <!-- الأتعاب والدفع -->
        <div class="form-card" style="margin-bottom:16px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #f0f0e8">
                <div style="width:28px;height:28px;background:#e8f0ea;border-radius:8px;display:flex;align-items:center;justify-content:center">
                    <i class="ti ti-currency-dollar" style="font-size:15px;color:#546B41"></i>
                </div>
                <span style="font-size:14px;font-weight:700;color:#3a4a28">الأتعاب وطريقة الدفع</span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
                <div class="form-group">
                    <label>الأتعاب المتفق عليها (ريال)</label>
                    <input type="number" step="0.01" id="agreeAmt" name="AgreeAmount" class="form-input"
                           value="@Model.AgreeAmount" oninput="calcRemain()">
                </div>
                <div class="form-group">
                    <label>المبلغ المدفوع (ريال)</label>
                    <input type="number" step="0.01" id="paidAmt" name="PaidAmount" class="form-input"
                           value="@Model.PaidAmount" oninput="calcRemain()">
                </div>
                <div class="form-group">
                    <label>المتبقي (محسوب تلقائياً)</label>
                    <input type="text" id="remainAmt" class="form-input"
                           style="background:#f8f8f4;font-weight:700;color:@(remaining > 0 ? "#c0392b" : "#2d6a4f")"
                           readonly value="@remaining.ToString("F2")">
                </div>
                <div class="form-group">
                    <label>طريقة الدفع</label>
                    <select name="PaymentMethod" class="form-input">
                        <option value="تحويل مصرفي" selected="@(Model.PaymentMethod == "تحويل مصرفي" ? "selected" : null)">تحويل مصرفي</option>
                        <option value="نقدي"        selected="@(Model.PaymentMethod == "نقدي"        ? "selected" : null)">نقدي</option>
                        <option value="شيك"         selected="@(Model.PaymentMethod == "شيك"         ? "selected" : null)">شيك</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>الحالة</label>
                    <select name="Status" class="form-input" id="statusSel">
                        <option value="قيد الدفع"     selected="@(Model.Status == "قيد الدفع"     ? "selected" : null)">قيد الدفع</option>
                        <option value="مدفوع جزئياً"  selected="@(Model.Status == "مدفوع جزئياً"  ? "selected" : null)">مدفوع جزئياً</option>
                        <option value="مدفوع كاملاً"  selected="@(Model.Status == "مدفوع كاملاً"  ? "selected" : null)">مدفوع كاملاً</option>
                        <option value="ملغى"           selected="@(Model.Status == "ملغى"           ? "selected" : null)">ملغى</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- ملاحظات -->
        <div class="form-card" style="margin-bottom:20px">
            <div class="form-group" style="margin:0">
                <label style="display:flex;align-items:center;gap:6px">
                    <i class="ti ti-notes" style="font-size:14px;color:#546B41"></i> ملاحظات
                </label>
                <textarea name="Notes" class="form-input" rows="3">@Model.Notes</textarea>
            </div>
        </div>

        <!-- أزرار -->
        <div style="display:flex;gap:12px;justify-content:flex-end">
            <a href="/PrivateLawyerSettlements" class="btn-cancel" style="display:inline-flex;align-items:center;gap:6px">
                <i class="ti ti-x"></i> إلغاء
            </a>
            <button type="submit" class="btn-save" style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px">
                <i class="ti ti-device-floppy"></i> حفظ التعديلات
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/users.css">
    <link rel="stylesheet" href="~/css/claims.css">
    <style>.form-input:focus{border-color:#546B41 !important;box-shadow:0 0 0 3px rgba(84,107,65,.12)}</style>
}

@section Scripts {
<script>
function calcRemain() {
    var agree = parseFloat(document.getElementById('agreeAmt').value) || 0;
    var paid  = parseFloat(document.getElementById('paidAmt').value)  || 0;
    var rem   = agree - paid;
    document.getElementById('remainAmt').value = rem.toFixed(2);
    document.getElementById('remainAmt').style.color = rem > 0 ? '#c0392b' : '#2d6a4f';
    var sel = document.getElementById('statusSel');
    if (agree > 0) {
        if (paid <= 0)         sel.value = 'قيد الدفع';
        else if (paid < agree) sel.value = 'مدفوع جزئياً';
        else                   sel.value = 'مدفوع كاملاً';
    }
}
</script>
}
