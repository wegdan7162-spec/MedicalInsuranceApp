@model List<MedicalInsuranceApp1.Models.Entities.Supplier>
@{
    ViewData["Title"] = "الموردون";
    string? search = ViewBag.Search;
    string? type   = ViewBag.Type;
    string? status = ViewBag.Status;
    int total         = ViewBag.Total         ?? 0;
    int activeCount   = ViewBag.ActiveCount   ?? 0;
    int inactiveCount = ViewBag.InactiveCount ?? 0;
}

<!-- رأس الصفحة -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
    <div>
        <h2 style="font-size:22px;font-weight:800;color:#fff;margin:0;display:flex;align-items:center;gap:10px">
            <span style="display:inline-flex;width:38px;height:38px;background:rgba(255,255,255,0.15);border-radius:10px;align-items:center;justify-content:center">
                <i class="ti ti-building-store" style="font-size:20px"></i>
            </span>
            الموردون
        </h2>
        <p style="font-size:12px;color:rgba(255,255,255,0.5);margin:6px 0 0 0">إدارة بيانات الجهات الموردة للأقساط</p>
    </div>
    <a href="/Suppliers/Create" class="btn-primary" style="text-decoration:none;padding:10px 22px;display:flex;align-items:center;gap:8px;border-radius:12px;font-size:13px">
        <i class="ti ti-plus" style="font-size:16px"></i> إضافة مورد جديد
    </a>
</div>

<!-- بطاقات الإحصاء -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px">
    <div style="background:#fff;border-radius:16px;padding:18px 22px;border:1px solid #edf0f5;box-shadow:0 2px 12px rgba(26,58,92,0.07);display:flex;align-items:center;gap:16px">
        <div style="width:50px;height:50px;background:#f0f6ff;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="ti ti-building-store" style="font-size:24px;color:#1a3a5c"></i>
        </div>
        <div>
            <div style="font-size:28px;font-weight:800;color:#1a3a5c;line-height:1">@total</div>
            <div style="font-size:11px;color:#aaa;margin-top:3px">إجمالي الموردين</div>
        </div>
    </div>
    <div style="background:#fff;border-radius:16px;padding:18px 22px;border:1px solid #edf0f5;box-shadow:0 2px 12px rgba(26,58,92,0.07);display:flex;align-items:center;gap:16px">
        <div style="width:50px;height:50px;background:#f0fff8;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="ti ti-circle-check" style="font-size:24px;color:#2d6a4f"></i>
        </div>
        <div>
            <div style="font-size:28px;font-weight:800;color:#2d6a4f;line-height:1">@activeCount</div>
            <div style="font-size:11px;color:#aaa;margin-top:3px">مورد نشط</div>
        </div>
    </div>
    <div style="background:#fff;border-radius:16px;padding:18px 22px;border:1px solid #edf0f5;box-shadow:0 2px 12px rgba(26,58,92,0.07);display:flex;align-items:center;gap:16px">
        <div style="width:50px;height:50px;background:#fff5f5;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="ti ti-circle-x" style="font-size:24px;color:#c0392b"></i>
        </div>
        <div>
            <div style="font-size:28px;font-weight:800;color:#c0392b;line-height:1">@inactiveCount</div>
            <div style="font-size:11px;color:#aaa;margin-top:3px">مورد متوقف</div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
<div style="background:linear-gradient(90deg,#e8f5ee,#f0fff8);color:#2d6a4f;padding:12px 18px;border-radius:12px;margin-bottom:16px;border-right:4px solid #2d6a4f;display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600">
    <i class="ti ti-circle-check" style="font-size:18px"></i> @TempData["Success"]
</div>
}

<!-- فلتر البحث -->
<div style="background:#fff;border-radius:16px;padding:18px 20px;margin-bottom:18px;box-shadow:0 2px 12px rgba(26,58,92,0.07);border:1px solid #edf0f5">
    <form method="get" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
        <div style="flex:2;min-width:180px">
            <label style="font-size:11px;font-weight:600;color:#888;margin-bottom:5px;display:block;letter-spacing:0.5px">
                <i class="ti ti-search" style="margin-left:3px"></i> بحث
            </label>
            <div style="position:relative">
                <input type="text" name="search" value="@search" class="sup-input" placeholder="اسم المورد، الهاتف، رقم العقد...">
            </div>
        </div>
        <div style="min-width:140px">
            <label style="font-size:11px;font-weight:600;color:#888;margin-bottom:5px;display:block;letter-spacing:0.5px">نوع الجهة</label>
            <select name="type" class="sup-input">
                <option value="" selected="@(type == null)">— الكل —</option>
                <option value="خاصة"    selected="@(type=="خاصة")">خاصة</option>
                <option value="حكومية"  selected="@(type=="حكومية")">حكومية</option>
                <option value="أخرى"    selected="@(type=="أخرى")">أخرى</option>
            </select>
        </div>
        <div style="min-width:130px">
            <label style="font-size:11px;font-weight:600;color:#888;margin-bottom:5px;display:block;letter-spacing:0.5px">الحالة</label>
            <select name="status" class="sup-input">
                <option value=""         selected="@(status==null)">— الكل —</option>
                <option value="active"   selected="@(status=="active")">✅ نشط</option>
                <option value="inactive" selected="@(status=="inactive")">⛔ غير نشط</option>
            </select>
        </div>
        <div style="display:flex;gap:8px">
            <button type="submit" class="btn-primary" style="padding:9px 20px;border-radius:10px;display:flex;align-items:center;gap:6px">
                <i class="ti ti-search"></i> بحث
            </button>
            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(type) || !string.IsNullOrEmpty(status))
            {
            <a href="/Suppliers" class="btn-cancel" style="text-decoration:none;padding:9px 14px;border-radius:10px;display:flex;align-items:center;gap:5px">
                <i class="ti ti-x"></i> مسح
            </a>
            }
        </div>
    </form>
</div>

<!-- الجدول -->
<div style="background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(26,58,92,0.08);border:1px solid #edf0f5">
    @if (!Model.Any())
    {
    <div style="text-align:center;padding:70px 30px">
        <div style="width:80px;height:80px;background:#f5f7fa;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
            <i class="ti ti-building-store" style="font-size:38px;color:#ccc"></i>
        </div>
        <div style="font-size:15px;font-weight:700;color:#bbb;margin-bottom:6px">لا يوجد موردون</div>
        <div style="font-size:12px;color:#ccc;margin-bottom:18px">ابدئي بإضافة أول مورد للنظام</div>
        <a href="/Suppliers/Create" class="btn-primary" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;padding:9px 22px">
            <i class="ti ti-plus"></i> إضافة مورد
        </a>
    </div>
    }
    else
    {
    <table style="width:100%;border-collapse:collapse">
        <thead>
            <tr style="background:#f8fafd;border-bottom:2px solid #edf0f5">
                <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#aaa;width:40px">#</th>
                <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#888">اسم المورد</th>
                <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#888">نوع الجهة</th>
                <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#888">رقم العقد</th>
                <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#888">الهاتف</th>
                <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#888">الحالة</th>
                <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#888;width:130px">الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @{ int idx = 1; }
            @foreach (var s in Model)
            {
            <tr style="border-bottom:1px solid #f5f7fa;transition:background 0.15s" onmouseover="this.style.background='#fafbfd'" onmouseout="this.style.background=''">
                <td style="padding:14px 16px;text-align:center;color:#ccc;font-size:12px">@(idx++)</td>
                <td style="padding:14px 16px">
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:36px;height:36px;background:linear-gradient(135deg,#e8f0fe,#d0e4ff);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:700;color:#1a3a5c;font-size:13px">
                            @(s.Name.Length > 0 ? s.Name[0].ToString() : "م")
                        </div>
                        <div>
                            <div style="font-weight:700;color:#1a3a5c;font-size:13px">@s.Name</div>
                            @if (!string.IsNullOrEmpty(s.Address))
                            {<div style="font-size:11px;color:#aaa;margin-top:1px"><i class="ti ti-map-pin" style="font-size:10px"></i> @s.Address</div>}
                            @if (!string.IsNullOrEmpty(s.Email))
                            {<div style="font-size:11px;color:#aaa;margin-top:1px"><i class="ti ti-mail" style="font-size:10px"></i> @s.Email</div>}
                        </div>
                    </div>
                </td>
                <td style="padding:14px 16px">
                    @if (!string.IsNullOrEmpty(s.EntityType))
                    {
                    var (bg,col) = s.EntityType == "حكومية"
                        ? ("#e8f5ff","#1a3a5c")
                        : s.EntityType == "خاصة"
                        ? ("#f0fff8","#2d6a4f")
                        : ("#f8f4ff","#6b4fbb");
                    <span style="background:@bg;color:@col;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700">@s.EntityType</span>
                    }
                    else { <span style="color:#ddd">—</span> }
                </td>
                <td style="padding:14px 16px;color:#555;font-size:12px;direction:ltr;font-family:monospace">
                    @(string.IsNullOrEmpty(s.ContractNumber) ? "—" : s.ContractNumber)
                </td>
                <td style="padding:14px 16px;color:#555;font-size:12px;direction:ltr">
                    @(string.IsNullOrEmpty(s.Phone) ? "—" : s.Phone)
                </td>
                <td style="padding:14px 16px;text-align:center">
                    @if (s.IsActive)
                    {<span style="background:#e8f5ee;color:#2d6a4f;padding:4px 14px;border-radius:20px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;gap:4px"><span style="width:6px;height:6px;background:#2d6a4f;border-radius:50%;display:inline-block"></span>نشط</span>}
                    else
                    {<span style="background:#fef0f0;color:#c0392b;padding:4px 14px;border-radius:20px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;gap:4px"><span style="width:6px;height:6px;background:#c0392b;border-radius:50%;display:inline-block"></span>متوقف</span>}
                </td>
                <td style="padding:14px 16px;text-align:center">
                    <div style="display:flex;gap:6px;justify-content:center">
                        <a href="/Suppliers/Edit/@s.Id"
                           style="width:32px;height:32px;background:#f0f6ff;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:#1a3a5c;transition:background 0.15s"
                           title="تعديل"
                           onmouseover="this.style.background='#1a3a5c';this.style.color='#fff'"
                           onmouseout="this.style.background='#f0f6ff';this.style.color='#1a3a5c'">
                            <i class="ti ti-pencil" style="font-size:15px"></i>
                        </a>
                        <button onclick="confirmDelete(@s.Id,'@s.Name.Replace("'","\\'")')"
                                style="width:32px;height:32px;background:#fff5f5;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;color:#c0392b;transition:background 0.15s"
                                title="حذف"
                                onmouseover="this.style.background='#c0392b';this.style.color='#fff'"
                                onmouseout="this.style.background='#fff5f5';this.style.color='#c0392b'">
                            <i class="ti ti-trash" style="font-size:15px"></i>
                        </button>
                    </div>
                </td>
            </tr>
            }
        </tbody>
    </table>
    <div style="padding:12px 20px;background:#f8fafd;border-top:1px solid #edf0f5;font-size:11px;color:#aaa;display:flex;align-items:center;justify-content:space-between">
        <span>إجمالي النتائج: <strong style="color:#1a3a5c">@Model.Count</strong> مورد</span>
        <span>آخر تحديث: @DateTime.Now.ToString("hh:mm tt")</span>
    </div>
    }
</div>

<!-- Modal حذف -->
<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:9999;align-items:center;justify-content:center;backdrop-filter:blur(4px)">
    <div style="background:#fff;border-radius:20px;padding:32px;width:440px;max-width:92%;box-shadow:0 20px 60px rgba(0,0,0,0.25);animation:slideUp 0.2s ease">
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
            <div style="width:48px;height:48px;background:#fff5f5;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="ti ti-trash" style="font-size:22px;color:#c0392b"></i>
            </div>
            <div>
                <h3 style="font-size:15px;font-weight:800;color:#1a3a5c;margin:0 0 3px">حذف المورد</h3>
                <p style="font-size:12px;color:#aaa;margin:0">هذا الإجراء يمكن التراجع عنه</p>
            </div>
        </div>
        <div style="background:#fff8f8;border-radius:12px;padding:12px 16px;margin-bottom:16px;border:1px solid #fde8e8">
            <p style="font-size:13px;color:#555;margin:0">سيتم حذف المورد: <strong id="deleteNameSpan" style="color:#c0392b"></strong></p>
        </div>
        <form id="deleteForm" method="post">
            @Html.AntiForgeryToken()
            <label style="font-size:12px;font-weight:600;color:#888;margin-bottom:6px;display:block">سبب الحذف (اختياري)</label>
            <input type="text" name="reason" placeholder="أدخل سبب الحذف..." class="sup-input" style="margin-bottom:18px">
            <div style="display:flex;gap:8px">
                <button type="button" onclick="closeModal()" class="btn-cancel" style="flex:1;padding:10px;border-radius:10px;font-size:13px">
                    <i class="ti ti-x"></i> إلغاء
                </button>
                <button type="submit" style="flex:1;background:linear-gradient(135deg,#c0392b,#e74c3c);color:#fff;border:none;padding:10px;border-radius:10px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:6px">
                    <i class="ti ti-trash"></i> تأكيد الحذف
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
<link rel="stylesheet" href="~/css/users.css">
<link rel="stylesheet" href="~/css/claims.css">
<style>
.sup-input {
    width: 100%;
    padding: 9px 14px;
    border: 1.5px solid #e8ecf3;
    border-radius: 10px;
    font-family: 'Cairo', sans-serif;
    font-size: 13px;
    color: #333;
    background: #fafbfd;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
}
.sup-input:focus {
    outline: none;
    border-color: #2d6a4f;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(45,106,79,0.1);
}
@@keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}
</style>
}

@section Scripts {
<script>
function confirmDelete(id, name) {
    document.getElementById('deleteNameSpan').textContent = name;
    document.getElementById('deleteForm').action = '/Suppliers/Delete/' + id;
    document.getElementById('deleteModal').style.display = 'flex';
}
function closeModal() {
    document.getElementById('deleteModal').style.display = 'none';
}
document.getElementById('deleteModal').addEventListener('click', function(e){
    if (e.target === this) closeModal();
});
</script>
}
